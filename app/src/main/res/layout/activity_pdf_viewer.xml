<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A1A">

    <!-- ── TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="#1A237E">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📄 PDF View"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_page_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Page 1 / 1"
            android:textColor="#B0BEC5"
            android:textSize="13sp"
            android:layout_marginEnd="12dp"/>



        <Button
            android:id="@+id/btn_pdf_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="✕"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#C62828"
            android:padding="0dp"/>

    </LinearLayout>

    <!-- ── PDF PAGE -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#2D2D2D">

        <ImageView
            android:id="@+id/img_pdf_page"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:padding="8dp"/>

    </ScrollView>

    <!-- ── BOTTOM NAVIGATION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#1A237E"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <Button
            android:id="@+id/btn_pdf_prev"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="◀ Prev"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#283593"
            android:layout_marginEnd="12dp"/>

        <Button
            android:id="@+id/btn_pdf_share"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Share"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00695C"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_pdf_next"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Next ▶"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#283593"/>

    </LinearLayout>

</LinearLayout>