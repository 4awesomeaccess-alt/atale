<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:elevation="12dp">

    <!-- ══ DRAG HANDLE ══ -->
    <LinearLayout
        android:id="@+id/drag_handle_sel"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:gravity="center"
        android:background="#F5F5F5">
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="#CCCCCC"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="DRAG &amp; DROP"
            android:textSize="11sp"
            android:textColor="#9E9E9E"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/btn_close_controls"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="✕"
            android:textSize="16sp"
            android:textColor="#757575"/>
    </LinearLayout>

    <!-- ══ ROW 1: Icon buttons (scrollable) ══ -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Lock -->
            <LinearLayout android:id="@+id/btn_sel_lock_text" style="@style/IconActionBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_lock" android:layout_gravity="center_horizontal" app:tint="#424242"/>
                <TextView style="@style/IconActionLabel" android:text="Lock"/>
            </LinearLayout>

            <!-- Copy -->
            <LinearLayout android:id="@+id/btn_copy_view" style="@style/IconActionBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_copy" android:layout_gravity="center_horizontal" app:tint="#424242"/>
                <TextView style="@style/IconActionLabel" android:text="Copy"/>
            </LinearLayout>

            <!-- Delete -->
            <LinearLayout android:id="@+id/btn_sel_delete_text" style="@style/IconActionBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_delete" android:layout_gravity="center_horizontal" app:tint="#424242"/>
                <TextView style="@style/IconActionLabel" android:text="Delete"/>
            </LinearLayout>

            <!-- Center -->
            <LinearLayout android:id="@+id/btn_center_text" style="@style/IconActionBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_center" android:layout_gravity="center_horizontal" app:tint="#424242"/>
                <TextView style="@style/IconActionLabel" android:text="Center"/>
            </LinearLayout>

            <!-- Flip V -->
            <LinearLayout android:id="@+id/btn_quick_flip_v" style="@style/IconActionBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_flip_v" android:layout_gravity="center_horizontal" app:tint="#424242"/>
                <TextView style="@style/IconActionLabel" android:text="Flip - V"/>
            </LinearLayout>

            <!-- Flip H -->
            <LinearLayout android:id="@+id/btn_quick_flip_h" style="@style/IconActionBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_flip_h" android:layout_gravity="center_horizontal" app:tint="#424242"/>
                <TextView style="@style/IconActionLabel" android:text="Flip - H"/>
            </LinearLayout>

            <!-- Layer UP (hidden) -->
            <LinearLayout android:id="@+id/btn_layer_up_text"
                style="@style/IconActionBtn" android:visibility="gone">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_add_page" android:layout_gravity="center_horizontal" app:tint="#424242"/>
                <TextView style="@style/IconActionLabel" android:text="Layer UP"/>
            </LinearLayout>

            <!-- Layer Down (hidden) -->
            <LinearLayout android:id="@+id/btn_layer_down_text"
                style="@style/IconActionBtn" android:visibility="gone">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_delete_page" android:layout_gravity="center_horizontal" app:tint="#424242"/>
                <TextView style="@style/IconActionLabel" android:text="Layer Down"/>
            </LinearLayout>

            <!-- Bold -->
            <LinearLayout android:id="@+id/btn_bold" style="@style/IconActionBtn">
                <ImageView
                    android:id="@+id/iv_bold"
                    android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/bold"
                    android:layout_gravity="center_horizontal"/>
                <TextView style="@style/IconActionLabel" android:text="Bold"/>
            </LinearLayout>

            <!-- Underline -->
            <LinearLayout android:id="@+id/btn_underline" style="@style/IconActionBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_underline" android:layout_gravity="center_horizontal" app:tint="#424242"/>
                <TextView style="@style/IconActionLabel" android:text="UnerLine"/>
            </LinearLayout>

            <!-- Overline -->
            <LinearLayout android:id="@+id/btn_overline" style="@style/IconActionBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_overline" android:layout_gravity="center_horizontal" app:tint="#424242"/>
                <TextView style="@style/IconActionLabel" android:text="UperLine"/>
            </LinearLayout>

            <!-- Strikethrough -->
            <LinearLayout android:id="@+id/btn_strikethrough" style="@style/IconActionBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_strikethrough" android:layout_gravity="center_horizontal" app:tint="#424242"/>
                <TextView style="@style/IconActionLabel" android:text="Strike"/>
            </LinearLayout>

            <!-- Italic -->
            <LinearLayout android:id="@+id/btn_italic" style="@style/IconActionBtn">
                <ImageView
                    android:id="@+id/iv_italic"
                    android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_italic"
                    android:layout_gravity="center_horizontal"/>
                <TextView style="@style/IconActionLabel" android:text="Italic"/>
            </LinearLayout>

        </LinearLayout>
    </HorizontalScrollView>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

    <!-- ══ SIZE ROW + MOVE BUTTONS ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="6dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <!-- Size seekbar area -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Size value -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tv_text_size_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="50"
                    android:textSize="13sp"
                    android:textColor="#212121"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"/>
            </LinearLayout>

            <!-- Seekbar row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/btn_size_minus"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:text="−"
                    android:textSize="18sp"
                    android:textColor="#424242"
                    android:background="#EEEEEE"/>
                <SeekBar
                    android:id="@+id/seek_text_size"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:max="300"
                    android:progress="50"
                    android:progressTint="#E57373"
                    android:thumbTint="#E57373"/>
                <TextView
                    android:id="@+id/btn_size_plus"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:text="+"
                    android:textSize="18sp"
                    android:textColor="#424242"
                    android:background="#EEEEEE"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Move buttons grid -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content">
                <TextView android:id="@+id/btn_move_up_text"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:gravity="center" android:text="↑"
                    android:textSize="16sp" android:textColor="#424242"
                    android:background="#F0F0F0" android:layout_marginEnd="2dp"/>
                <TextView android:id="@+id/btn_move_down_text"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:gravity="center" android:text="↓"
                    android:textSize="16sp" android:textColor="#424242"
                    android:background="#F0F0F0"/>
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="2dp">
                <TextView android:id="@+id/btn_move_right_text"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:gravity="center" android:text="→"
                    android:textSize="16sp" android:textColor="#424242"
                    android:background="#F0F0F0" android:layout_marginEnd="2dp"/>
                <TextView android:id="@+id/btn_move_left_text"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:gravity="center" android:text="←"
                    android:textSize="16sp" android:textColor="#424242"
                    android:background="#F0F0F0"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

    <!-- ══ GRID: Feature buttons ══ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="6dp">

            <!-- Row 1 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="6dp">
                <LinearLayout android:id="@+id/btn_re_edit" style="@style/GridFeatureBtn">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_edit" app:tint="#424242"/>
                    <TextView style="@style/GridFeatureLabel" android:text="Re Edit"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/btn_text_color" style="@style/GridFeatureBtn">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_color" app:tint="#424242"/>
                    <TextView style="@style/GridFeatureLabel" android:text="Color"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/btn_font_pick" style="@style/GridFeatureBtn">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Aa" android:textSize="18sp" android:textColor="#424242" android:textStyle="bold"/>
                    <TextView style="@style/GridFeatureLabel" android:text="Font"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/btn_align_text" style="@style/GridFeatureBtn">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_multiselect" app:tint="#424242"/>
                    <TextView style="@style/GridFeatureLabel" android:text="Align"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/tab_spacing" style="@style/GridFeatureBtn">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="↕≡" android:textSize="18sp" android:textColor="#424242"/>
                    <TextView style="@style/GridFeatureLabel" android:text="Space"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="6dp">
                <LinearLayout android:id="@+id/tab_transform" style="@style/GridFeatureBtn">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⬡" android:textSize="18sp" android:textColor="#424242"/>
                    <TextView style="@style/GridFeatureLabel" android:text="Transform"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/btn_bg_color" style="@style/GridFeatureBtn">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_bg_color" app:tint="#424242"/>
                    <TextView style="@style/GridFeatureLabel" android:text="BG"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/btn_stroke_color" style="@style/GridFeatureBtn">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="T̲" android:textSize="18sp" android:textColor="#424242"/>
                    <TextView style="@style/GridFeatureLabel" android:text="Text Stroke"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/btn_text_size_panel" style="@style/GridFeatureBtn">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_text_size" app:tint="#E57373"/>
                    <TextView style="@style/GridFeatureLabel" android:text="Text Size" android:textColor="#E57373"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/tab_effects" style="@style/GridFeatureBtn">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="◐" android:textSize="18sp" android:textColor="#424242"/>
                    <TextView style="@style/GridFeatureLabel" android:text="Visual"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Row 3 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout android:id="@+id/btn_bg_border" style="@style/GridFeatureBtn">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⬜" android:textSize="18sp" android:textColor="#424242"/>
                    <TextView style="@style/GridFeatureLabel" android:text="BG Border"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/tab_visual" style="@style/GridFeatureBtn">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="☁" android:textSize="18sp" android:textColor="#424242"/>
                    <TextView style="@style/GridFeatureLabel" android:text="Shadow"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/tab_typo" style="@style/GridFeatureBtn">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ω" android:textSize="18sp" android:textColor="#424242"/>
                    <TextView style="@style/GridFeatureLabel" android:text="Typo"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/tab_layout" style="@style/GridFeatureBtn" android:visibility="gone">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⬆⬇" android:textSize="18sp" android:textColor="#424242"/>
                    <TextView style="@style/GridFeatureLabel" android:text="Layer"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/tab_transform2"
                    android:layout_width="0dp" android:layout_height="0dp"
                    android:layout_weight="1" android:visibility="gone"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Hidden panels -->
    <LinearLayout android:id="@+id/panel_tab_action" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone"/>
    <LinearLayout android:id="@+id/panel_tab_spacing" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone"/>
    <LinearLayout android:id="@+id/panel_tab_effects" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone"/>
    <LinearLayout android:id="@+id/panel_tab_layout" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone"/>
    <LinearLayout android:id="@+id/panel_tab_transform" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone"/>

</LinearLayout>
