<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <!-- ══ DRAG HANDLE HEADER ══ -->
    <LinearLayout
        android:id="@+id/drag_handle_sel"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:text="DRAG &amp; DROP"
            android:textColor="#111827"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_close_controls"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="✕"
            android:textColor="#6B7280"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E5E7EB" />

    <!-- ══ ROW 1: Icon Actions (HorizontalScrollView) ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="6dp"
        android:paddingEnd="8dp"
        android:paddingBottom="6dp">

        <!-- Size bar -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="8dp"
        android:paddingTop="6dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/btn_sel_lock_text"
                style="@style/IconActionBtn">

                <ImageView
                    android:id="@+id/iv_lock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_lock" />

                <TextView
                    style="@style/IconActionLabel"
                    android:text="Lock" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_copy_view"
                style="@style/IconActionBtn">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_copy" />

                <TextView
                    style="@style/IconActionLabel"
                    android:text="Copy" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_sel_delete_text"
                style="@style/IconActionBtn">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_delete" />

                <TextView
                    style="@style/IconActionLabel"
                    android:text="Delete" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_center_text"
                style="@style/IconActionBtn">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_center" />

                <TextView
                    style="@style/IconActionLabel"
                    android:text="Center" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_quick_flip_v"
                style="@style/IconActionBtn">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_verticle" />

                <TextView
                    style="@style/IconActionLabel"
                    android:text="Flip - V" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_quick_flip_h"
                style="@style/IconActionBtn">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_horizental" />

                <TextView
                    style="@style/IconActionLabel"
                    android:text="Flip - H" />
            </LinearLayout>
        </LinearLayout>
    </HorizontalScrollView>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="8dp"
        android:paddingTop="6dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/tab_layout"
                style="@style/IconActionBtn"
                android:visibility="gone">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_overline" />

                <TextView
                    style="@style/IconActionLabel"
                    android:text="Layer UP" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_bold"
                style="@style/IconActionBtn">

                <ImageView
                    android:id="@+id/iv_bold"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/bold" />

                <TextView
                    style="@style/IconActionLabel"
                    android:text="Bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_underline"
                style="@style/IconActionBtn">

                <ImageView
                    android:id="@+id/iv_line"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_underline" />

                <TextView
                    style="@style/IconActionLabel"
                    android:text="UnerLine" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_overline"
                style="@style/IconActionBtn">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_underline" />

                <TextView
                    style="@style/IconActionLabel"
                    android:text="UperLine" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_italic"
                style="@style/IconActionBtn">

                <ImageView
                    android:id="@+id/iv_italic"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_italic" />

                <TextView
                    style="@style/IconActionLabel"
                    android:text="Italic" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_strikethrough"
                style="@style/IconActionBtn">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_strikethrough" />

                <TextView
                    style="@style/IconActionLabel"
                    android:text="Strike" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_strikethrough11"
                style="@style/IconActionBtn">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_strikethrough" />

                <TextView
                    style="@style/IconActionLabel"
                    android:text="Strike" />
            </LinearLayout>



        </LinearLayout>
    </HorizontalScrollView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btn_move_up"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="2dp"
                    android:background="#F3F4F6"
                    android:padding="6dp"
                    android:src="@drawable/ic_top"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/btn_move_down"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="#F3F4F6"
                    android:padding="6dp"
                    android:src="@drawable/ic_bottom"
                    android:scaleType="fitCenter" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btn_move_right"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="2dp"
                    android:background="#F3F4F6"
                    android:padding="6dp"
                    android:src="@drawable/ic_right"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/btn_move_left"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="#F3F4F6"
                    android:padding="6dp"
                    android:src="@drawable/ic_left"
                    android:scaleType="fitCenter" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="#E5E7EB" />

    <!-- ══ SIZE + MOVE ROW ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="6dp"
        android:paddingEnd="8dp"
        android:paddingBottom="6dp">

        <!-- Size bar -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- seekbar row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="#F9FAFB"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/btn_size_minus"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="#E5E7EB"
                    android:gravity="center"
                    android:text="−"
                    android:textColor="#374151"
                    android:textSize="18sp" />

                <SeekBar
                    android:id="@+id/seek_text_size"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:max="300"
                    android:progress="50"
                    android:progressTint="#EF4444"
                    android:thumbTint="#EF4444" />

                <TextView
                    android:id="@+id/tv_text_size_val"
                    android:layout_width="28dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="50"
                    android:textColor="#111827"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_size_plus"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="4dp"
                    android:background="#E5E7EB"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="#374151"
                    android:textSize="18sp" />

            </LinearLayout>
        </LinearLayout>

        <!-- Move buttons 2x2 -->


    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E5E7EB" />

    <!-- ══ GRID: Feature buttons ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="6dp">


        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/btn_re_edit"
                style="@style/GridFeatureBtn">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_edit" />

                <TextView
                    style="@style/GridFeatureLabel"
                    android:text="Re Edit" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_text_size_panel"
                style="@style/GridFeatureBtn">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_text_size" />

                <TextView
                    style="@style/GridFeatureLabel"
                    android:text="Text Size" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_text_color"
                style="@style/GridFeatureBtn">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_color" />

                <TextView
                    style="@style/GridFeatureLabel"
                    android:text="Color" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_bg_color"
                style="@style/GridFeatureBtn">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_backgroud" />

                <TextView
                    style="@style/GridFeatureLabel"
                    android:text="BG" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_bg_border"
                style="@style/GridFeatureBtn">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_bg_border" />

                <TextView
                    style="@style/GridFeatureLabel"
                    android:text="BG Border" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_align_text"
                style="@style/GridFeatureBtn">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_align" />

                <TextView
                    style="@style/GridFeatureLabel"
                    android:text="Align" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_font_pick"
                style="@style/GridFeatureBtn">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_font" />

                <TextView
                    style="@style/GridFeatureLabel"
                    android:text="Font" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/tab_spacing"
                style="@style/GridFeatureBtn">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_space" />

                <TextView
                    style="@style/GridFeatureLabel"
                    android:text="Space" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_transform"
                style="@style/GridFeatureBtn">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_transfrom" />

                <TextView
                    style="@style/GridFeatureLabel"
                    android:text="Transform" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_effects"
                style="@style/GridFeatureBtn">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_color" />

                <TextView
                    style="@style/GridFeatureLabel"
                    android:text="Effects" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_stroke_color"
                style="@style/GridFeatureBtn">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_edit" />

                <TextView
                    style="@style/GridFeatureLabel"
                    android:text="Stroke" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_visual"
                style="@style/GridFeatureBtn">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_multiselect" />

                <TextView
                    style="@style/GridFeatureLabel"
                    android:text="Visual" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_typo"
                style="@style/GridFeatureBtn">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_add_text" />

                <TextView
                    style="@style/GridFeatureLabel"
                    android:text="Typo" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Hidden panels -->
    <LinearLayout
        android:id="@+id/panel_tab_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/panel_tab_spacing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/panel_tab_effects"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/panel_tab_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/panel_tab_transform"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone" />

</LinearLayout>
