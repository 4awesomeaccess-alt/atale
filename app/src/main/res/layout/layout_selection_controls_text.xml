<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- ══ DRAG HANDLE HEADER ══ -->
    <LinearLayout
        android:id="@+id/drag_handle_sel"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:background="#FFFFFF">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DRAG &amp; DROP"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:letterSpacing="0.1"
            android:gravity="center"/>

        <TextView
            android:id="@+id/btn_close_controls"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="✕"
            android:textSize="16sp"
            android:textColor="#6B7280"/>

    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB"/>

    <!-- ══ ROW 1: Icon Actions (HorizontalScrollView) ══ -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout android:id="@+id/btn_sel_lock_text" style="@style/IconActionBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_lock" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/IconActionLabel" android:text="Lock"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btn_copy_view" style="@style/IconActionBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_copy" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/IconActionLabel" android:text="Copy"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btn_sel_delete_text" style="@style/IconActionBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_delete" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/IconActionLabel" android:text="Delete"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btn_center_text" style="@style/IconActionBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_center" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/IconActionLabel" android:text="Center"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btn_quick_flip_v" style="@style/IconActionBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_flip_v" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/IconActionLabel" android:text="Flip - V"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btn_quick_flip_h" style="@style/IconActionBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_flip_h" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/IconActionLabel" android:text="Flip - H"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/tab_layout" style="@style/IconActionBtn" android:visibility="gone">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_overline" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/IconActionLabel" android:text="Layer UP"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btn_bold" style="@style/IconActionBtn">
                <ImageView android:id="@+id/iv_bold" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/bold" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/IconActionLabel" android:text="Bold"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btn_underline" style="@style/IconActionBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_underline" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/IconActionLabel" android:text="UnerLine"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btn_overline" style="@style/IconActionBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_overline" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/IconActionLabel" android:text="UperLine"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btn_italic" style="@style/IconActionBtn">
                <ImageView android:id="@+id/iv_italic" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_italic" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/IconActionLabel" android:text="Italic"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btn_strikethrough" style="@style/IconActionBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_strikethrough" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/IconActionLabel" android:text="Strike"/>
            </LinearLayout>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB" android:layout_marginStart="12dp" android:layout_marginEnd="12dp"/>

    <!-- ══ SIZE + MOVE ROW ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:gravity="center_vertical">

        <!-- Size bar -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- seekbar row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#F9FAFB"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/btn_size_minus"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:text="−"
                    android:textSize="18sp"
                    android:textColor="#374151"
                    android:background="#E5E7EB"/>

                <SeekBar
                    android:id="@+id/seek_text_size"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:max="300"
                    android:progress="50"
                    android:progressTint="#EF4444"
                    android:thumbTint="#EF4444"/>

                <TextView
                    android:id="@+id/tv_text_size_val"
                    android:layout_width="28dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="50"
                    android:textSize="12sp"
                    android:textColor="#111827"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/btn_size_plus"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:text="+"
                    android:textSize="18sp"
                    android:textColor="#374151"
                    android:background="#E5E7EB"
                    android:layout_marginStart="4dp"/>

            </LinearLayout>
        </LinearLayout>

        <!-- Move buttons 2x2 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="6dp">

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:id="@+id/btn_move_up"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:gravity="center" android:text="↑" android:textSize="16sp"
                    android:textColor="#374151" android:background="#F3F4F6" android:layout_marginEnd="2dp"/>
                <TextView android:id="@+id/btn_move_down"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:gravity="center" android:text="↓" android:textSize="16sp"
                    android:textColor="#374151" android:background="#F3F4F6"/>
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
                <TextView android:id="@+id/btn_move_right"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:gravity="center" android:text="→" android:textSize="16sp"
                    android:textColor="#374151" android:background="#F3F4F6" android:layout_marginEnd="2dp"/>
                <TextView android:id="@+id/btn_move_left"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:gravity="center" android:text="←" android:textSize="16sp"
                    android:textColor="#374151" android:background="#F3F4F6"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB"/>

    <!-- ══ GRID: Feature buttons ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="6dp">

        <!-- Row 1 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="4dp">
            <LinearLayout android:id="@+id/btn_re_edit" style="@style/GridFeatureBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_edit" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/GridFeatureLabel" android:text="Re Edit"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/btn_text_size_panel" style="@style/GridFeatureBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_text_size" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/GridFeatureLabel" android:text="Text Size"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/btn_text_color" style="@style/GridFeatureBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_color" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/GridFeatureLabel" android:text="Color"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/btn_bg_color" style="@style/GridFeatureBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_bg_color" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/GridFeatureLabel" android:text="BG"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/btn_bg_border" style="@style/GridFeatureBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_add_image" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/GridFeatureLabel" android:text="BG Border"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/btn_align_text" style="@style/GridFeatureBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_multiselect" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/GridFeatureLabel" android:text="Align"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/btn_font_pick" style="@style/GridFeatureBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_add_text" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/GridFeatureLabel" android:text="Font"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <LinearLayout android:id="@+id/tab_spacing" style="@style/GridFeatureBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_multiselect" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/GridFeatureLabel" android:text="Space"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/tab_transform" style="@style/GridFeatureBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_cutnew" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/GridFeatureLabel" android:text="Transform"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/tab_effects" style="@style/GridFeatureBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_color" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/GridFeatureLabel" android:text="Effects"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/btn_stroke_color" style="@style/GridFeatureBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_edit" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/GridFeatureLabel" android:text="Stroke"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/tab_visual" style="@style/GridFeatureBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_multiselect" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/GridFeatureLabel" android:text="Visual"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/tab_typo" style="@style/GridFeatureBtn">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_add_text" android:layout_gravity="center_horizontal"/>
                <TextView style="@style/GridFeatureLabel" android:text="Typo"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Hidden panels -->
    <LinearLayout android:id="@+id/panel_tab_action"    android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone"/>
    <LinearLayout android:id="@+id/panel_tab_spacing"   android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone"/>
    <LinearLayout android:id="@+id/panel_tab_effects"   android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone"/>
    <LinearLayout android:id="@+id/panel_tab_layout"    android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone"/>
    <LinearLayout android:id="@+id/panel_tab_transform" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone"/>

</LinearLayout>
