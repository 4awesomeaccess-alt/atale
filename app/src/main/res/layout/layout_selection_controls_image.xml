<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_text_tool_popup">

    <!-- Drag Handle -->
    <LinearLayout
        android:id="@+id/drag_handle_sel"
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:gravity="center"
        android:background="#F1F5F9"
        android:orientation="horizontal">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="#CBD5E1"
            android:layout_gravity="center" />

    </LinearLayout>

    <!-- Row 1: Action Buttons -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Delete -->
            <LinearLayout
                android:id="@+id/btn_pop_delete"
                style="@style/GridFeatureBtn">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    android:src="@drawable/ic_delete" />
                            <TextView
                    style="@style/GridFeatureLabel"
                    android:text="Delete" />
</LinearLayout>

            <!-- Duplicate -->
            <LinearLayout
                android:id="@+id/btn_duplicate_view"
                style="@style/GridFeatureBtn">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    android:src="@drawable/ic_copy" />
                            <TextView
                    style="@style/GridFeatureLabel"
                    android:text="Copy" />
</LinearLayout>

            <!-- Layer Up -->
            <LinearLayout
                android:id="@+id/btn_layer_up"
                style="@style/GridFeatureBtn">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    android:src="@drawable/selector_layer_up" />
                            <TextView
                    style="@style/GridFeatureLabel"
                    android:text="Layer+" />
</LinearLayout>

            <!-- Layer Down -->
            <LinearLayout
                android:id="@+id/btn_layer_down"
                style="@style/GridFeatureBtn">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    android:src="@drawable/selector_layer_down" />
                            <TextView
                    style="@style/GridFeatureLabel"
                    android:text="Layer-" />
</LinearLayout>

            <!-- Layer Top -->
            <LinearLayout
                android:id="@+id/btn_layer_top"
                style="@style/GridFeatureBtn">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    android:src="@drawable/ic_layer_up" />
                            <TextView
                    style="@style/GridFeatureLabel"
                    android:text="Top" />
</LinearLayout>

            <!-- Layer Bottom -->
            <LinearLayout
                android:id="@+id/btn_layer_bottom"
                style="@style/GridFeatureBtn">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    android:src="@drawable/ic_layer_down" />
                            <TextView
                    style="@style/GridFeatureLabel"
                    android:text="Bottom" />
</LinearLayout>

            <!-- Flip H -->
            <LinearLayout
                android:id="@+id/btn_flip_h"
                style="@style/GridFeatureBtn">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    android:src="@android:drawable/ic_menu_rotate" />
                            <TextView
                    style="@style/GridFeatureLabel"
                    android:text="Flip" />
</LinearLayout>

            <!-- Opacity -->
            <LinearLayout
                android:id="@+id/btn_opacity"
                style="@style/GridFeatureBtn">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    android:src="@android:drawable/ic_menu_manage" />
                            <TextView
                    style="@style/GridFeatureLabel"
                    android:text="Opacity" />
</LinearLayout>

            <!-- Move -->
            <LinearLayout
                android:id="@+id/btn_brightness"
                style="@style/GridFeatureBtn">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    android:src="@drawable/ic_top" />
                            <TextView
                    style="@style/GridFeatureLabel"
                    android:text="Move" />
</LinearLayout>

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Size Seekbar Row -->
    <LinearLayout
        android:id="@+id/main_liner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="6dp">

        <!-- Seekbar container -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_seekbar_container"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Size label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Size"
                    android:textSize="10sp"
                    android:textColor="#6B7280"
                    android:layout_marginEnd="4dp" />

                <!-- Size value -->
                <TextView
                    android:id="@+id/tv_sel_size_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100"
                    android:textSize="10sp"
                    android:textColor="#374151"
                    android:textStyle="bold"
                    android:layout_weight="1" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Minus -->
                <TextView
                    android:id="@+id/btn_sel_size_minus"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_seekbar_btn"
                    android:gravity="center"
                    android:text="−"
                    android:textColor="#EF4444"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- SeekBar -->
                <SeekBar
                    android:id="@+id/seek_sel_size"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:max="500"
                    android:progress="250"
                    android:progressTint="#1565C0"
                    android:thumbTint="#1565C0" />

                <!-- Plus -->
                <TextView
                    android:id="@+id/btn_sel_size_plus"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_seekbar_btn"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="#374151"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- Move Buttons -->
        <LinearLayout
            android:id="@+id/move_liner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_seekbar_container"
            android:padding="6dp"
            android:gravity="center">

            <!-- Up -->
            <ImageView
                android:id="@+id/btn_sel_up"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/selector_move_btn"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/selector_move_top" />

            <!-- Middle Row: Left + Right -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp">

                <ImageView
                    android:id="@+id/btn_sel_left"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/selector_move_btn"
                    android:padding="6dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/selector_move_left" />

                <!-- Center dot -->
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"
                    android:background="@drawable/bg_dpad_center"
                    android:layout_gravity="center" />

                <ImageView
                    android:id="@+id/btn_sel_right"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/selector_move_btn"
                    android:padding="6dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/selector_move_right" />

            </LinearLayout>

            <!-- Down -->
            <ImageView
                android:id="@+id/btn_sel_down"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/selector_move_btn"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/selector_move_bottom" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
