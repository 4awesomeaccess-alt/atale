<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111111">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1565C0"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Photo Set કરો"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Single Edit Tab -->
    <TextView
        android:id="@+id/tv_tab_edit"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center"
        android:text="✏️ Edit"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="#1565C0"/>

    <!-- Edit Area -->
    <FrameLayout
        android:id="@+id/fl_edit"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Canvas -->
            <FrameLayout
                android:id="@+id/fl_canvas"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="#222222">

                <ImageView
                    android:id="@+id/iv_edit_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:adjustViewBounds="true"/>
            </FrameLayout>

            <!-- Rotation SeekBar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1A1A1A"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔄"
                    android:textSize="14sp"
                    android:paddingEnd="6dp"/>

                <SeekBar
                    android:id="@+id/seek_rotation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="359"
                    android:progress="0"/>

                <TextView
                    android:id="@+id/tv_rotation_val"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:text="0°"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:paddingStart="6dp"/>
            </LinearLayout>

            <!-- Controls -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#1A1A1A"
                android:padding="6dp">

                <Button
                    android:id="@+id/btn_zoom_out"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="🔍−"
                    android:textSize="14sp"
                    android:backgroundTint="#333333"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="3dp"/>

                <Button
                    android:id="@+id/btn_zoom_in"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="🔍+"
                    android:textSize="14sp"
                    android:backgroundTint="#333333"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="3dp"/>

                <Button
                    android:id="@+id/btn_rotate_left"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="↺15°"
                    android:textSize="12sp"
                    android:backgroundTint="#333333"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="3dp"/>

                <Button
                    android:id="@+id/btn_rotate_right"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="↻15°"
                    android:textSize="12sp"
                    android:backgroundTint="#333333"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="3dp"/>

                <Button
                    android:id="@+id/btn_reset_transform"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Reset"
                    android:textSize="11sp"
                    android:backgroundTint="#F57C00"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- Bottom buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#111111"
        android:padding="8dp">

        <Button
            android:id="@+id/btn_cancel_photo"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:backgroundTint="#616161"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_change_photo"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="📷 Photo"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:backgroundTint="#1565C0"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_done"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="✅ Done"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:backgroundTint="#43A047"/>
    </LinearLayout>

</LinearLayout>