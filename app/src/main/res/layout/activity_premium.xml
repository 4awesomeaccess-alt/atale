<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Close Button -->
        <TextView
            android:id="@+id/btn_premium_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textColor="#888888"
            android:textSize="22sp"
            android:padding="8dp"
            android:layout_gravity="end"/>

        <!-- Crown Icon -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👑"
            android:textSize="64sp"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp"/>

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Premium Unlock"
            android:textColor="#FFD700"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Unlimited access to all features"
            android:textColor="#8888AA"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <!-- Features -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A2E"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp" android:gravity="center_vertical">
                <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="🚫" android:textSize="20sp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="No Watermark" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Export clean images without watermark" android:textColor="#8888AA" android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp" android:gravity="center_vertical">
                <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="📄" android:textSize="20sp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PDF Export" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Export your cards as PDF" android:textColor="#8888AA" android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp" android:gravity="center_vertical">
                <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="🖼" android:textSize="20sp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Full HD Export" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="High quality image export" android:textColor="#8888AA" android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="⭐" android:textSize="20sp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Premium Stickers" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Access all premium sticker collections" android:textColor="#8888AA" android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Weekly Plan Card -->
        <LinearLayout
            android:id="@+id/card_weekly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#16213E"
            android:padding="16dp"
            android:layout_marginBottom="10dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Weekly Plan" android:textColor="#FFFFFF" android:textSize="17sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tv_weekly_price"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Loading..." android:textColor="#FFD700" android:textSize="14sp"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/btn_weekly_subscribe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subscribe"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="#E94560"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Monthly Plan Card -->
        <LinearLayout
            android:id="@+id/card_monthly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1040"
            android:padding="16dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 BEST VALUE"
                android:textColor="#FFD700"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Monthly Plan" android:textColor="#FFFFFF" android:textSize="17sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tv_monthly_price"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Loading..." android:textColor="#FFD700" android:textSize="14sp"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/btn_monthly_subscribe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subscribe"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="#7C3AED"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Restore -->
        <TextView
            android:id="@+id/btn_restore_purchase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Restore Purchase"
            android:textColor="#5566AA"
            android:textSize="13sp"
            android:gravity="center"
            android:padding="10dp"/>

        <!-- Terms -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Subscription auto-renews. Cancel anytime."
            android:textColor="#555566"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="4dp"/>

    </LinearLayout>
</ScrollView>
