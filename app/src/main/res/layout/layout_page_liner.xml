<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/page_liner"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center"
    android:padding="8dp"
    android:background="@drawable/bg_page_nav">

    <LinearLayout
        android:id="@+id/btn_prev_page"
        style="@style/PageNavButton">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_arrow_left"
            android:tint="@android:color/white"/>
    </LinearLayout>

    <TextView
        android:id="@+id/txt_page_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:text="1 / 1"
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="@android:color/white"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:background="@drawable/bg_page_indicator" />

    <LinearLayout
        android:id="@+id/btn_next_page"
        style="@style/PageNavButton">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_arrow_right"
            android:tint="@android:color/white"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bt_multiselect"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_marginStart="10dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:background="@drawable/bg_multiselect_btn"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_multiselect"
            android:tint="@android:color/white"/>

        <TextView
            android:id="@+id/tv_multiselect_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Multi"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginStart="6dp"/>
    </LinearLayout>

</LinearLayout>