<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/curve_root"
    android:layout_width="match_parent"
    android:layout_height="160dp"
    android:orientation="vertical"
    android:background="#2A3439"
    android:elevation="16dp">

    <!-- Drag Title Bar -->
    <LinearLayout
        android:id="@+id/curve_drag_handle"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="#1C2529"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⠿ "
            android:textColor="#9CA3AF"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="〜 Curve Text"
            android:textColor="#F3F4F6"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/curve_btn_done"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:text="Done ✓"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:background="#4CAF50"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/curve_btn_close"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:text="✕"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:gravity="center"
            android:background="#374151" />

    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:padding="10dp">

        <!-- Left: Curve type buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingEnd="12dp">

            <!-- None -->
            <TextView
                android:id="@+id/curve_btn_none"
                android:layout_width="52dp"
                android:layout_height="34dp"
                android:text="None"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:gravity="center"
                android:background="#607D8B"
                android:layout_marginBottom="6dp" />

            <!-- Arc Up -->
            <TextView
                android:id="@+id/curve_btn_up"
                android:layout_width="52dp"
                android:layout_height="34dp"
                android:text="⌢ Up"
                android:textColor="#9CA3AF"
                android:textSize="10sp"
                android:gravity="center"
                android:background="#374151"
                android:layout_marginBottom="6dp" />

            <!-- Arc Down -->
            <TextView
                android:id="@+id/curve_btn_down"
                android:layout_width="52dp"
                android:layout_height="34dp"
                android:text="⌣ Down"
                android:textColor="#9CA3AF"
                android:textSize="10sp"
                android:gravity="center"
                android:background="#374151" />

        </LinearLayout>

        <!-- Right: Radius slider -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Radius"
                android:textColor="#9CA3AF"
                android:textSize="10sp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <SeekBar
                    android:id="@+id/curve_seek_radius"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="50"
                    android:progressTint="#4CAF50"
                    android:thumbTint="#CFD8DC" />

                <TextView
                    android:id="@+id/curve_radius_val"
                    android:layout_width="28dp"
                    android:layout_height="wrap_content"
                    android:text="50"
                    android:textColor="#CFD8DC"
                    android:textSize="9sp"
                    android:gravity="end"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <!-- Remove curve -->
            <TextView
                android:id="@+id/curve_btn_remove"
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:text="✕ Remove Curve"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:gravity="center"
                android:background="#B71C1C" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
