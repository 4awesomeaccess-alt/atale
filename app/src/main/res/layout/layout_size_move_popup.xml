<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <!-- DRAG HANDLE + CLOSE -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:background="#37474F">
        <TextView
            android:id="@+id/drag_handle_size_move"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="⤢ Size &amp; Move  ↕"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:gravity="center"/>
        <TextView
            android:id="@+id/btn_size_move_close"
            android:layout_width="36dp"
            android:layout_height="match_parent"
            android:text="✕"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="#B71C1C"/>
    </LinearLayout>

    <!-- MAIN CARD -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#ECEFF1"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <!-- SIZE SEEKBAR ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⤢"
                android:textSize="14sp"
                android:textColor="#37474F"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/btn_sm_size_minus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="−"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="#546E7A"
                android:layout_marginEnd="4dp"/>

            <SeekBar
                android:id="@+id/seek_sm_size"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="50"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/btn_sm_size_plus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="+"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="#546E7A"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tv_sm_size_label"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:text="W:0 H:0"
                android:textSize="9sp"
                android:textColor="#37474F"
                android:gravity="center"/>
        </LinearLayout>

        <!-- MOVE BUTTONS ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Left spacer -->
            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            <TextView
                android:id="@+id/btn_sm_left"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="◀"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="#546E7A"
                android:layout_marginEnd="4dp"/>

            <!-- Up/Down stacked -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginEnd="4dp">
                <TextView
                    android:id="@+id/btn_sm_up"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="▲"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="#546E7A"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:id="@+id/btn_sm_down"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="▼"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="#546E7A"/>
            </LinearLayout>

            <TextView
                android:id="@+id/btn_sm_right"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="▶"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="#546E7A"
                android:layout_marginEnd="4dp"/>

            <!-- Right spacer -->
            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        </LinearLayout>

    </LinearLayout>
</LinearLayout>
