<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111111">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="#1565C0"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Freehand Crop"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Draw to select area"
            android:textColor="#BBDEFB"
            android:textSize="10sp"/>

    </LinearLayout>

    <!-- Mode Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="#1A1A1A">

        <TextView
            android:id="@+id/tab_freehand"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="✏️ Freehand"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#1565C0"
            android:clickable="true"
            android:focusable="true"/>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#333333"/>

        <TextView
            android:id="@+id/tab_polygon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⬡ Polygon"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#888888"
            android:background="#1A1A1A"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- Image + Freehand overlay -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000">

        <ImageView
            android:id="@+id/iv_freehand_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"/>

        <com.example.newcardmaker.FreehandCropView
            android:id="@+id/freehand_crop_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </FrameLayout>

    <!-- Polygon hint -->
    <TextView
        android:id="@+id/tv_polygon_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap to add points. First point પર tap = close"
        android:textColor="#BBBBBB"
        android:textSize="11sp"
        android:gravity="center"
        android:padding="6dp"
        android:background="#1A1A1A"
        android:visibility="gone"/>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#111111"
        android:padding="6dp">

        <Button
            android:id="@+id/btn_freehand_clear"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="🗑 Clear"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:backgroundTint="#F57C00"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_freehand_cancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:backgroundTint="#616161"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_freehand_apply"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="2"
            android:text="✅ Apply Cut"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:backgroundTint="#43A047"/>

    </LinearLayout>

</LinearLayout>