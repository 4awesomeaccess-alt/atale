<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F0F4FF"
    android:elevation="12dp"
    android:orientation="vertical"
    android:padding="6dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="4dp"
        android:weightSum="4"
        android:orientation="horizontal">
    <!--   ── Drag Handle ──   -->
    <TextView
        android:id="@+id/drag_handle_frame"
        android:layout_width="0dp"
        android:layout_height="30dp"
        android:background="#1565C0"
        android:gravity="center"
        android:layout_weight="1.7"
        android:text="🖼 Frame Controls ↕ Drag"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/btn_frame_popup_close"
        android:layout_width="0dp"
        android:layout_height="30dp"
        android:layout_weight="0.3"
        android:background="#37474F"
        android:gravity="center"
        android:text="✕ Close"
        android:textColor="#FFFFFF"
        android:textSize="11sp" />

        <TextView
            android:id="@+id/btn_frame_quick_lock"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginEnd="3dp"
            android:layout_weight="1"
            android:background="#E8F5E9"
            android:gravity="center"
            android:text="🔓 Lock"
            android:textColor="#1B5E20"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/btn_frame_quick_delete"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:background="#FF1744"
            android:gravity="center"
            android:text="🗑 Delete"
            android:textColor="#FFFFFF"
            android:textSize="10sp" />
    </LinearLayout>
    <!--   ── 4 Tabs ──   -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tab_frame_photo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#1565C0"
            android:gravity="center"
            android:text="📷 Photo"
            android:textColor="#FFFFFF"
            android:textSize="9sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#FFFFFF" />

        <TextView
            android:id="@+id/tab_frame_color"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#BBDEFB"
            android:gravity="center"
            android:text="🎨 Color"
            android:textColor="#1565C0"
            android:textSize="9sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#FFFFFF" />

        <TextView
            android:id="@+id/tab_frame_adjust"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#BBDEFB"
            android:gravity="center"
            android:text="⚙ Adjust"
            android:textColor="#1565C0"
            android:textSize="9sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#FFFFFF" />

        <TextView
            android:id="@+id/tab_frame_position"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#BBDEFB"
            android:gravity="center"
            android:text="↔ Move"
            android:textColor="#1565C0"
            android:textSize="9sp" />
    </LinearLayout>
    <!--  Size Quick Control - Always Visible  -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingEnd="4dp"
            android:text="⤡"
            android:textColor="#555555"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/btn_photo_tab_size_minus"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="#37474F"
            android:gravity="center"
            android:text="−"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <SeekBar
            android:id="@+id/seek_photo_tab_size"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="50" />

        <TextView
            android:id="@+id/btn_photo_tab_size_plus"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="#37474F"
            android:gravity="center"
            android:text="+"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_photo_tab_size_label"
            android:layout_width="56dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="W:0 H:0"
            android:textColor="#1565C0"
            android:textSize="8sp"
            android:textStyle="bold" />
    </LinearLayout>
    <!--   ── Scrollable Panels (150dp fixed height) ──   -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <!--   PANEL 1: PHOTO   -->
            <LinearLayout
                android:id="@+id/panel_frame_photo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4"
                android:visibility="visible">

                <TextView
                    android:id="@+id/btn_frame_select_photo"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:background="#1565C0"
                    android:gravity="center"
                    android:text="📷 Photo Select / Change"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_frame_adjust_photo"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="34dp"
                    android:layout_marginTop="3dp"
                    android:background="#2E7D32"
                    android:gravity="center"
                    android:text="🔍 Photo Adjust (Pinch Zoom / Pan)"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/btn_frame_replace_photo"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="34dp"
                    android:layout_marginTop="3dp"
                    android:background="#E65100"
                    android:gravity="center"
                    android:text="🔄 Frame Style Change"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/btn_frame_remove_photo"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="34dp"
                    android:layout_marginTop="3dp"
                    android:background="#C62828"
                    android:gravity="center"
                    android:text="✕ Photo Remove (Keep Frame)"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>
            <!--   PANEL 2: COLOR   -->
            <LinearLayout
                android:id="@+id/panel_frame_color"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="☀ Brightness"
                        android:textColor="#333333"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/tv_brightness_label"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="0"
                        android:textColor="#1565C0"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_brightness"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="200"
                    android:progress="100" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="◑ Contrast"
                        android:textColor="#333333"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/tv_contrast_label"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="0"
                        android:textColor="#1565C0"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_contrast"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="200"
                    android:progress="100" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🌈 Saturation"
                        android:textColor="#333333"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/tv_saturation_label"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="0"
                        android:textColor="#1565C0"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_saturation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="200"
                    android:progress="100" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Frame Overlay Tint:"
                    android:textColor="#555555"
                    android:textSize="10sp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp">

                    <LinearLayout
                        android:id="@+id/row_tint_colors"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:orientation="horizontal"
                        android:padding="2dp" />
                </HorizontalScrollView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_frame_tint_custom"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="3dp"
                        android:layout_weight="1"
                        android:background="#E65100"
                        android:gravity="center"
                        android:text="🎨 Custom Tint"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/btn_frame_remove_tint"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:background="#616161"
                        android:gravity="center"
                        android:text="✕ Remove Tint"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btn_frame_color_reset"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:layout_marginTop="3dp"
                    android:background="#37474F"
                    android:gravity="center"
                    android:text="↺ Reset Color Filters"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp" />
            </LinearLayout>
            <!--   PANEL 3: ADJUST   -->
            <LinearLayout
                android:id="@+id/panel_frame_adjust"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <!--  Size row  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⤡ Size"
                        android:textColor="#333333"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/tv_frame_size_label"
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="W:0 H:0"
                        android:textColor="#1565C0"
                        android:textSize="9sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_frame_size_minus"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="#37474F"
                        android:gravity="center"
                        android:text="−"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <SeekBar
                        android:id="@+id/seek_frame_size"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="4dp"
                        android:layout_weight="1"
                        android:max="100"
                        android:progress="50" />

                    <TextView
                        android:id="@+id/btn_frame_size_plus"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="#37474F"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />
                </LinearLayout>
                <!--  Rotation row  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="↻ Rotation"
                        android:textColor="#333333"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/tv_frame_rotation_label"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="0°"
                        android:textColor="#1565C0"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_frame_rot_minus"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="#37474F"
                        android:gravity="center"
                        android:text="−"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <SeekBar
                        android:id="@+id/seek_frame_rotation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="4dp"
                        android:layout_weight="1"
                        android:max="360"
                        android:progress="180" />

                    <TextView
                        android:id="@+id/btn_frame_rot_plus"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="#37474F"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />
                </LinearLayout>
                <!--  Opacity row  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="◎ Opacity"
                        android:textColor="#333333"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/tv_frame_opacity_label"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="100%"
                        android:textColor="#1565C0"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_frame_opacity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="100" />
                <!--  Flip row  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_frame_flip_h"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_marginEnd="3dp"
                        android:layout_weight="1"
                        android:background="#546E7A"
                        android:gravity="center"
                        android:text="↔ Flip H"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/btn_frame_flip_v"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_weight="1"
                        android:background="#546E7A"
                        android:gravity="center"
                        android:text="↕ Flip V"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
            <!--   PANEL 4: MOVE / POSITION   -->
            <LinearLayout
                android:id="@+id/panel_frame_position"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <!--  D-Pad  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_frame_move_left"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="#37474F"
                        android:gravity="center"
                        android:text="◀"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp" />

                    <LinearLayout
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="3dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/btn_frame_move_up"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="#37474F"
                            android:gravity="center"
                            android:text="▲"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp" />

                        <TextView
                            android:id="@+id/btn_frame_move_down"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginTop="3dp"
                            android:background="#37474F"
                            android:gravity="center"
                            android:text="▼"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btn_frame_move_right"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="#37474F"
                        android:gravity="center"
                        android:text="▶"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp" />
                </LinearLayout>
                <!--  Center align  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_frame_align_center_h"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:layout_marginEnd="3dp"
                        android:layout_weight="1"
                        android:background="#1565C0"
                        android:gravity="center"
                        android:text="⟺ Center H"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/btn_frame_align_center_v"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:layout_weight="1"
                        android:background="#1565C0"
                        android:gravity="center"
                        android:text="⟸ Center V"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp" />
                </LinearLayout>
                <!--  Layer buttons  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_frame_bring_front"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_marginEnd="2dp"
                        android:layout_weight="1"
                        android:background="#1565C0"
                        android:gravity="center"
                        android:text="⬆⬆ Front"
                        android:textColor="#FFFFFF"
                        android:textSize="8sp" />

                    <TextView
                        android:id="@+id/btn_frame_layer_up"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_marginEnd="2dp"
                        android:layout_weight="1"
                        android:background="#1976D2"
                        android:gravity="center"
                        android:text="⬆ Up"
                        android:textColor="#FFFFFF"
                        android:textSize="8sp" />

                    <TextView
                        android:id="@+id/btn_frame_layer_down"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_marginEnd="2dp"
                        android:layout_weight="1"
                        android:background="#C62828"
                        android:gravity="center"
                        android:text="⬇ Down"
                        android:textColor="#FFFFFF"
                        android:textSize="8sp" />

                    <TextView
                        android:id="@+id/btn_frame_send_back"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_weight="1"
                        android:background="#B71C1C"
                        android:gravity="center"
                        android:text="⬇⬇ Back"
                        android:textColor="#FFFFFF"
                        android:textSize="8sp" />
                </LinearLayout>
                <!--  Lock + Delete  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_frame_lock"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_marginEnd="3dp"
                        android:layout_weight="1"
                        android:background="#E8F5E9"
                        android:gravity="center"
                        android:text="🔓 Lock"
                        android:textColor="#1B5E20"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/btn_frame_delete"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_weight="1"
                        android:background="#FF1744"
                        android:gravity="center"
                        android:text="🗑 Delete"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <!--   ── Close ──   -->

</LinearLayout>