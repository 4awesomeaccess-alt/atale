<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drag_handle_sel"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="#CC000000"
    android:elevation="12dp"
    android:orientation="vertical"
    android:padding="6dp"
    android:minWidth="280dp">

    <!-- ══ ROW 1: Header — Drag + Close ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1A1A1A"
        android:paddingStart="8dp"
        android:paddingEnd="4dp"
        android:layout_marginBottom="6dp">

        <!-- Drag icon -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⠿ Controls"
            android:textColor="#AAAAAA"
            android:textSize="11sp" />

        <!-- Close -->
        <TextView
            android:id="@+id/btn_sel_close"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="✕"
            android:textColor="#FF5555"
            android:textSize="14sp"
            android:background="?attr/selectableItemBackground" />
    </LinearLayout>

    <!-- ══ ROW 2: Size + Edit ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <!-- Edit Text — text only -->
        <TextView
            android:id="@+id/btn_sel_edit_text"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:gravity="center"
            android:text="✏"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="#1565C0"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginEnd="4dp"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sz"
            android:textColor="#AAAAAA"
            android:textSize="10sp"
            android:layout_marginEnd="4dp" />

        <!-- Size Minus -->
        <TextView
            android:id="@+id/btn_sel_size_minus"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:gravity="center"
            android:text="−"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="#444444" />

        <!-- SeekBar -->
        <SeekBar
            android:id="@+id/seek_sel_size"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:max="100"
            android:progress="50" />

        <!-- Size Plus -->
        <TextView
            android:id="@+id/btn_sel_size_plus"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:gravity="center"
            android:text="+"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="#444444" />

        <!-- Label -->
        <TextView
            android:id="@+id/tv_sel_size_label"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:gravity="center" />

    </LinearLayout>

    <!-- ══ DIVIDER ══ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginBottom="4dp" />

    <!-- ══ ROW 3: Toggle Buttons Row ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="4dp">

        <!-- Move Toggle -->
        <TextView
            android:id="@+id/btn_toggle_move"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="↕ Move 1"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:background="#37474F"
            android:layout_marginEnd="3dp" />

        <!-- Layer Toggle -->
        <TextView
            android:id="@+id/btn_toggle_layer"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="📚 Layer"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:background="#4A148C"
            android:layout_marginEnd="3dp" />

        <!-- Align Toggle -->
        <TextView
            android:id="@+id/btn_toggle_align"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⬤ Align"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:background="#1565C0" />

    </LinearLayout>

    <!-- ══ MOVE ROW — initially GONE ══ -->
    <LinearLayout
        android:id="@+id/row_move_btns"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/btn_sel_left"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="◀"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="#444444"
            android:layout_marginEnd="4dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="4dp">

            <TextView
                android:id="@+id/btn_sel_up"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="▲"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="#444444"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/btn_sel_down"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="▼"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="#444444" />

        </LinearLayout>

        <TextView
            android:id="@+id/btn_sel_right"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="▶"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="#444444" />

    </LinearLayout>

    <!-- ══ LAYER ROW — initially GONE ══ -->
    <LinearLayout
        android:id="@+id/row_layer_btns"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/btn_pop_bring_front"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⤒ Top"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:background="#6A1B9A"
            android:layout_marginEnd="3dp" />

        <TextView
            android:id="@+id/btn_pop_layer_up"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="↑ Up"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:background="#7B1FA2"
            android:layout_marginEnd="3dp" />

        <TextView
            android:id="@+id/btn_pop_layer_down"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="↓ Down"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:background="#8E24AA"
            android:layout_marginEnd="3dp" />

        <TextView
            android:id="@+id/btn_pop_send_back"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⤓ Bot"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:background="#9C27B0" />

    </LinearLayout>

    <!-- ══ ALIGN ROW — initially GONE ══ -->
    <HorizontalScrollView
        android:id="@+id/hsv_align_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="2dp">

            <TextView
                android:id="@+id/btn_sel_align_left"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="3dp"
                android:background="#1A237E"
                android:gravity="center"
                android:text="⬤←"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/btn_sel_align_center_h"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="3dp"
                android:background="#1A237E"
                android:gravity="center"
                android:text="⬤↔"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/btn_sel_align_right"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="3dp"
                android:background="#1A237E"
                android:gravity="center"
                android:text="→⬤"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#444444"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp" />

            <TextView
                android:id="@+id/btn_sel_align_top"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="3dp"
                android:background="#0D47A1"
                android:gravity="center"
                android:text="⬤↑"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/btn_sel_align_middle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="3dp"
                android:background="#0D47A1"
                android:gravity="center"
                android:text="⬤↕"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/btn_sel_align_bottom"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="3dp"
                android:background="#0D47A1"
                android:gravity="center"
                android:text="⬤↓"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#444444"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp" />

            <TextView
                android:id="@+id/btn_sel_distribute_h"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="3dp"
                android:background="#01579B"
                android:gravity="center"
                android:text="↔↔"
                android:textColor="#FFFFFF"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/btn_sel_distribute_v"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="#01579B"
                android:gravity="center"
                android:text="↕↕"
                android:textColor="#FFFFFF"
                android:textSize="10sp" />

        </LinearLayout>
    </HorizontalScrollView>

</LinearLayout>