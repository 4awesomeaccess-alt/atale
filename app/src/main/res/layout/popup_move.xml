<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_text_tool_popup"
    android:elevation="4dp"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/move_drag_handle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⇢ Move  ⠿"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#111827"
        android:padding="4dp"
        android:layout_marginBottom="8dp" />

    <!-- Move Speed -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Speed"
        android:textSize="11sp"
        android:textColor="#6B7280"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <SeekBar
            android:id="@+id/seek_move_speed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:max="100"
            android:progress="5"
            android:progressTint="#10B981"
            android:thumbTint="#10B981" />

        <TextView
            android:id="@+id/tv_move_speed_val"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="5"
            android:textColor="#111827"
            android:textSize="10sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Move Buttons D-Pad -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/popup_btn_move_up"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/selector_move_btn"
            android:padding="8dp"
            android:src="@drawable/selector_move_top"
            android:scaleType="fitCenter" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <ImageView
                android:id="@+id/popup_btn_move_left"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/selector_move_btn"
                android:padding="8dp"
                android:src="@drawable/selector_move_left"
                android:scaleType="fitCenter" />

            <View
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="4dp" />

            <ImageView
                android:id="@+id/popup_btn_move_right"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/selector_move_btn"
                android:padding="8dp"
                android:src="@drawable/selector_move_right"
                android:scaleType="fitCenter" />

        </LinearLayout>

        <ImageView
            android:id="@+id/popup_btn_move_down"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/selector_move_btn"
            android:padding="8dp"
            android:src="@drawable/selector_move_bottom"
            android:scaleType="fitCenter" />

    </LinearLayout>

</LinearLayout>
