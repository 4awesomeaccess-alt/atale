<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/photo_adjust_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111">

    <TextView
        android:id="@+id/tv_adjust_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="#1E1E1E"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="📷 Adjust Your Photo"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/top_buttons"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_below="@id/tv_adjust_title"
        android:background="#1A1A1A"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="6dp">

        <Button
            android:id="@+id/btn_adjust_cancel"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:backgroundTint="#333333"
            android:text="Cancel"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_adjust_reset"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:backgroundTint="#444444"
            android:text="↺ Reset"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_adjust_apply"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:backgroundTint="#2196F3"
            android:text="✔ Apply"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

    <View
        android:id="@+id/photo_adjust_preview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

         />

    <ImageView
        android:id="@+id/photo_adjust_touch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="fitCenter"
        android:background="@android:color/transparent" />

    <LinearLayout
        android:id="@+id/panel_brightness"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_above="@id/bottom_toolbar"
        android:background="#CC1E1E1E"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="☀"
            android:textColor="#FFC107"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/seek_brightness"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:progressTint="#FFC107"
            android:thumbTint="#FFC107" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/panel_contrast"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_above="@id/bottom_toolbar"
        android:background="#CC1E1E1E"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="◑"
            android:textColor="#4FC3F7"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/seek_contrast"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:progressTint="#4FC3F7"
            android:thumbTint="#4FC3F7" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottom_toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="#1A1A1A"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/btn_tool_brightness"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☀"
                android:textColor="#FFC107"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bright"
                android:textColor="#AAAAAA"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_tool_contrast"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◑"
                android:textColor="#4FC3F7"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contrast"
                android:textColor="#AAAAAA"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_tool_rotate_left"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↺"
                android:textColor="#81C784"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rot L"
                android:textColor="#AAAAAA"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_tool_rotate_right"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↻"
                android:textColor="#81C784"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rot R"
                android:textColor="#AAAAAA"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_tool_flip_h"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⇔"
                android:textColor="#CE93D8"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Flip H"
                android:textColor="#AAAAAA"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_tool_flip_v"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⇕"
                android:textColor="#CE93D8"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Flip V"
                android:textColor="#AAAAAA"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_tool_crop"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✂"
                android:textColor="#FF8A65"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crop"
                android:textColor="#AAAAAA"
                android:textSize="9sp" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>