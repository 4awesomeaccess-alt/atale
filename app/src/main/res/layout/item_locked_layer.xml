<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="10dp"
        android:background="?android:attr/selectableItemBackground">

        <!-- Lock Status -->
        <TextView
            android:id="@+id/tv_lock_status"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:textSize="14sp"
            android:text="🔓"
            android:background="@drawable/invite_background_2_border_black_extra"
            android:layout_marginEnd="8dp"/>

        <!-- Type Badge -->
        <TextView
            android:id="@+id/tv_layer_type"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:gravity="center"
            android:textSize="11sp"
            android:textStyle="bold"
            android:text="T"
            android:layout_marginEnd="8dp"/>

        <!-- Preview -->
        <ImageView
            android:id="@+id/iv_layer_preview"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerCrop"
            android:background="#F5F5F5"
            android:layout_marginEnd="10dp"/>

        <!-- Label -->
        <TextView
            android:id="@+id/tv_layer_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textColor="#212121"
            android:maxLines="2"
            android:ellipsize="end"/>

        <!-- Action Button -->
        <TextView
            android:id="@+id/btn_layer_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒 Lock"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:padding="8dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/invite_background_2_border_black_extra"/>

        <!-- existing buttons ની નીચે ઉમેરો -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/btn_layer_up"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="▲"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="#1565C0"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/btn_layer_down"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="▼"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="#1565C0"/>

        </LinearLayout>


    </LinearLayout>
    <Button
        android:id="@+id/btn_layer_restore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="↩ Restore"
        android:textSize="11sp"
        android:backgroundTint="#E8F5E9"
        android:textColor="#1B5E20"
        android:visibility="gone"
        android:padding="6dp"/>
    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        android:layout_marginStart="16dp"/>

</LinearLayout>