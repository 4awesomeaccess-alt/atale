<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1A1A2E"
    android:padding="20dp">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⭐ Premium Unlock"
        android:textColor="#FFD700"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Watermark remove • HD Export • Premium Stickers"
        android:textColor="#B0B0C0"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <!-- Weekly Plan -->
    <LinearLayout
        android:id="@+id/card_weekly"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#16213E"
        android:padding="16dp"
        android:layout_marginBottom="10dp"
        android:gravity="center_vertical">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Weekly" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tv_weekly_price" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Loading..." android:textColor="#B0B0C0" android:textSize="13sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/btn_weekly_subscribe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Subscribe"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="#E94560"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"/>
    </LinearLayout>

    <!-- Monthly Plan -->
    <LinearLayout
        android:id="@+id/card_monthly"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#16213E"
        android:padding="16dp"
        android:layout_marginBottom="20dp"
        android:gravity="center_vertical">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Monthly" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text=" BEST VALUE" android:textColor="#FFD700" android:textSize="10sp" android:textStyle="bold" android:layout_marginStart="6dp"/>
            </LinearLayout>
            <TextView android:id="@+id/tv_monthly_price" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Loading..." android:textColor="#B0B0C0" android:textSize="13sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/btn_monthly_subscribe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Subscribe"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="#E94560"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"/>
    </LinearLayout>

    <!-- Features list -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="✓  Watermark dure thay" android:textColor="#A0FFA0" android:textSize="13sp" android:layout_marginBottom="4dp"/>
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="✓  Full HD Export" android:textColor="#A0FFA0" android:textSize="13sp" android:layout_marginBottom="4dp"/>
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="✓  Premium Stickers unlock" android:textColor="#A0FFA0" android:textSize="13sp" android:layout_marginBottom="16dp"/>

    <!-- Close -->
    <TextView
        android:id="@+id/btn_sub_close"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="Maybe Later"
        android:textColor="#888888"
        android:textSize="13sp"
        android:gravity="center"/>

</LinearLayout>
