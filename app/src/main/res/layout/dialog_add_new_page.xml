<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:fillViewport="true">

  <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:padding="20dp">

      <View
          android:layout_width="40dp"
          android:layout_height="4dp"
          android:layout_gravity="center_horizontal"
          android:background="@drawable/bg_handle_bar"
          android:layout_marginBottom="14dp"/>

      <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="Add New Page"
          android:textSize="20sp"
          android:textStyle="bold"
          android:textColor="#212121"
          android:gravity="center"
          android:layout_marginBottom="16dp"/>

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:background="@drawable/bg_manage_action_btn"
          android:padding="4dp">

          <!-- Add After Current Page -->
          <LinearLayout
              android:id="@+id/opt_add_after"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal"
              android:gravity="center_vertical"
              android:padding="12dp"
              android:clickable="true"
              android:focusable="true">

              <TextView
                  android:layout_width="40dp"
                  android:layout_height="40dp"
                  android:text="⤵"
                  android:textSize="18sp"
                  android:textColor="#2E7D32"
                  android:gravity="center"
                  android:background="@drawable/bg_iconbox_green"/>

              <LinearLayout
                  android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1"
                  android:orientation="vertical"
                  android:layout_marginStart="12dp">
                  <TextView
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="Add After Current Page"
                      android:textSize="15sp"
                      android:textStyle="bold"
                      android:textColor="#212121"/>
                  <TextView
                      android:id="@+id/sub_add_after"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="Insert new page after Page 01"
                      android:textSize="12sp"
                      android:textColor="#9E9E9E"/>
              </LinearLayout>

              <View
                  android:id="@+id/radio_add_after"
                  android:layout_width="22dp"
                  android:layout_height="22dp"
                  android:background="@drawable/bg_radio_unselected"/>
          </LinearLayout>

          <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0"/>

          <!-- Add Before Current Page -->
          <LinearLayout
              android:id="@+id/opt_add_before"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal"
              android:gravity="center_vertical"
              android:padding="12dp"
              android:clickable="true"
              android:focusable="true">

              <TextView
                  android:layout_width="40dp"
                  android:layout_height="40dp"
                  android:text="⤴"
                  android:textSize="18sp"
                  android:textColor="#1565C0"
                  android:gravity="center"
                  android:background="@drawable/bg_iconbox_blue"/>

              <LinearLayout
                  android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1"
                  android:orientation="vertical"
                  android:layout_marginStart="12dp">
                  <TextView
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="Add Before Current Page"
                      android:textSize="15sp"
                      android:textStyle="bold"
                      android:textColor="#212121"/>
                  <TextView
                      android:id="@+id/sub_add_before"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="Insert new page before Page 01"
                      android:textSize="12sp"
                      android:textColor="#9E9E9E"/>
              </LinearLayout>

              <View
                  android:id="@+id/radio_add_before"
                  android:layout_width="22dp"
                  android:layout_height="22dp"
                  android:background="@drawable/bg_radio_unselected"/>
          </LinearLayout>

          <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0"/>

          <!-- Add At End -->
          <LinearLayout
              android:id="@+id/opt_add_end"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal"
              android:gravity="center_vertical"
              android:padding="12dp"
              android:clickable="true"
              android:focusable="true">

              <TextView
                  android:layout_width="40dp"
                  android:layout_height="40dp"
                  android:text="⤓"
                  android:textSize="18sp"
                  android:textColor="#EF6C00"
                  android:gravity="center"
                  android:background="@drawable/bg_iconbox_orange"/>

              <LinearLayout
                  android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1"
                  android:orientation="vertical"
                  android:layout_marginStart="12dp">
                  <TextView
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="Add At End"
                      android:textSize="15sp"
                      android:textStyle="bold"
                      android:textColor="#212121"/>
                  <TextView
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="Add new page at the end"
                      android:textSize="12sp"
                      android:textColor="#9E9E9E"/>
              </LinearLayout>

              <View
                  android:id="@+id/radio_add_end"
                  android:layout_width="22dp"
                  android:layout_height="22dp"
                  android:background="@drawable/bg_radio_unselected"/>
          </LinearLayout>

          <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0"/>

          <!-- Choose Position -->
          <LinearLayout
              android:id="@+id/opt_choose_pos"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal"
              android:gravity="center_vertical"
              android:padding="12dp"
              android:clickable="true"
              android:focusable="true">

              <TextView
                  android:layout_width="40dp"
                  android:layout_height="40dp"
                  android:text="▦"
                  android:textSize="18sp"
                  android:textColor="#6A1B9A"
                  android:gravity="center"
                  android:background="@drawable/bg_iconbox_purple"/>

              <LinearLayout
                  android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1"
                  android:orientation="vertical"
                  android:layout_marginStart="12dp">
                  <TextView
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="Choose Position"
                      android:textSize="15sp"
                      android:textStyle="bold"
                      android:textColor="#212121"/>
                  <TextView
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="Choose specific position to insert"
                      android:textSize="12sp"
                      android:textColor="#9E9E9E"/>
              </LinearLayout>

              <View
                  android:id="@+id/radio_choose_pos"
                  android:layout_width="22dp"
                  android:layout_height="22dp"
                  android:background="@drawable/bg_radio_unselected"/>
          </LinearLayout>

          <!-- Position grid (built in code) -->
          <GridLayout
              android:id="@+id/grid_add_positions"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_gravity="center_horizontal"
              android:columnCount="4"
              android:layout_marginStart="12dp"
              android:layout_marginEnd="12dp"
              android:layout_marginBottom="10dp"/>
      </LinearLayout>

      <!-- Bottom buttons -->
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:layout_marginTop="16dp">

          <LinearLayout
              android:id="@+id/btn_add_confirm"
              android:layout_width="0dp"
              android:layout_height="52dp"
              android:layout_weight="1"
              android:layout_marginEnd="6dp"
              android:orientation="horizontal"
              android:gravity="center"
              android:background="@drawable/bg_add_confirm_btn"
              android:clickable="true"
              android:focusable="true">

              <TextView
                  android:id="@+id/tv_add_pos_badge"
                  android:layout_width="26dp"
                  android:layout_height="26dp"
                  android:text="01"
                  android:textSize="11sp"
                  android:textStyle="bold"
                  android:textColor="#E53935"
                  android:gravity="center"
                  android:background="@drawable/bg_pos_badge"
                  android:layout_marginEnd="8dp"/>

              <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="Add New Page"
                  android:textSize="15sp"
                  android:textStyle="bold"
                  android:textColor="#FFFFFF"/>
          </LinearLayout>

          <TextView
              android:id="@+id/btn_add_cancel"
              android:layout_width="0dp"
              android:layout_height="52dp"
              android:layout_weight="1"
              android:layout_marginStart="6dp"
              android:text="Cancel"
              android:textSize="15sp"
              android:textColor="#424242"
              android:gravity="center"
              android:background="@drawable/bg_add_cancel_btn"
              android:clickable="true"
              android:focusable="true"/>
      </LinearLayout>

  </LinearLayout>
</ScrollView>
