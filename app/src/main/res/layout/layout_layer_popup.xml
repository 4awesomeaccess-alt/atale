<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <!-- DRAG HANDLE + CLOSE -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:background="#1B5E20">
        <TextView
            android:id="@+id/drag_handle_layer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="⧈ Layer  ↕"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:gravity="center"/>
        <TextView
            android:id="@+id/btn_layer_close"
            android:layout_width="36dp"
            android:layout_height="match_parent"
            android:text="✕"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="#B71C1C"/>
    </LinearLayout>

    <!-- MAIN CARD -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#E8F5E9"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <LinearLayout android:id="@+id/btn_layer_front"
            android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="#1B5E20" android:layout_marginEnd="3dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⬆" android:textSize="18sp" android:textColor="#FFFFFF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Front" android:textSize="9sp" android:textColor="#A5D6A7"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_layer_up"
            android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="#2E7D32" android:layout_marginEnd="3dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="↑" android:textSize="18sp" android:textColor="#FFFFFF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Up" android:textSize="9sp" android:textColor="#C8E6C9"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_layer_down"
            android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="#388E3C" android:layout_marginEnd="3dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="↓" android:textSize="18sp" android:textColor="#FFFFFF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Down" android:textSize="9sp" android:textColor="#C8E6C9"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_layer_back"
            android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="#1B5E20">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⬇" android:textSize="18sp" android:textColor="#FFFFFF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Back" android:textSize="9sp" android:textColor="#A5D6A7"/>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
