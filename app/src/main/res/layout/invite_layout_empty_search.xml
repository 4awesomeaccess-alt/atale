<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ll_empty"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/_20sdp"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_contact_card"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Description Text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="2dp"
            android:text="જો તમને અન્ય કોઈ કેટેગરીમાં આમંત્રણ કાર્ડ અથવા સોશિયલ મીડિયા કાર્ડ બનાવવું હોય, તો કૃપા કરીને અમને જાણ કરો અથવા ડેમો મોકલો. અમે તેને એપમાં ઉમેરવાનો પ્રયાસ કરીશું."
            android:textColor="#555555"
            android:textSize="14sp" />

        <!-- Space -->
        <View
            android:layout_width="match_parent"
            android:layout_height="16dp" />

        <!-- WhatsApp Button -->
        <LinearLayout
            android:id="@+id/btn_whatsapp"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/bg_whatsapp_button"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_whatsapp_circle"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_whatsapp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Whatsapp થી અમારો સંપર્ક કરો"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>