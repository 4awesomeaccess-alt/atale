<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a1a">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#212121"
        android:padding="12dp"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✏ Edit Image"
            android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"/>
        <Button android:id="@+id/btn_cancel_edit"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="Cancel" android:textColor="#FFFFFF"
            android:background="#616161" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btn_save_edit"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="✓ Save" android:textColor="#FFFFFF"
            android:background="#1565C0"/>
    </LinearLayout>

    <!-- Preview -->
    <ImageView android:id="@+id/iv_edit_preview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="fitCenter"
        android:background="#2a2a2a"/>

    <!-- Controls -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#212121">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Brightness -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="Brightness" android:textColor="#AAAAAA" android:textSize="11sp"/>
                <SeekBar android:id="@+id/sb_brightness"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:layout_marginStart="8dp" android:layout_marginEnd="8dp"/>
                <TextView android:id="@+id/tv_brightness_val"
                    android:layout_width="36dp" android:layout_height="wrap_content"
                    android:text="0" android:textColor="#FFFFFF" android:gravity="center" android:textSize="11sp"/>
            </LinearLayout>

            <!-- Contrast -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="Contrast" android:textColor="#AAAAAA" android:textSize="11sp"/>
                <SeekBar android:id="@+id/sb_contrast"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:layout_marginStart="8dp" android:layout_marginEnd="8dp"/>
                <TextView android:id="@+id/tv_contrast_val"
                    android:layout_width="36dp" android:layout_height="wrap_content"
                    android:text="1.0" android:textColor="#FFFFFF" android:gravity="center" android:textSize="11sp"/>
            </LinearLayout>

            <!-- Saturation -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="Saturation" android:textColor="#AAAAAA" android:textSize="11sp"/>
                <SeekBar android:id="@+id/sb_saturation"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:layout_marginStart="8dp" android:layout_marginEnd="8dp"/>
                <TextView android:id="@+id/tv_saturation_val"
                    android:layout_width="36dp" android:layout_height="wrap_content"
                    android:text="1.0" android:textColor="#FFFFFF" android:gravity="center" android:textSize="11sp"/>
            </LinearLayout>

            <!-- Action buttons -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center">
                <Button android:id="@+id/btn_rotate_left"
                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="↺ Left"
                    android:textColor="#FFFFFF" android:background="#374151" android:textSize="11sp"/>
                <Button android:id="@+id/btn_rotate_right"
                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="↻ Right"
                    android:textColor="#FFFFFF" android:background="#374151" android:textSize="11sp"/>
                <Button android:id="@+id/btn_flip_h"
                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="⇔ Flip H"
                    android:textColor="#FFFFFF" android:background="#374151" android:textSize="11sp"/>
                <Button android:id="@+id/btn_flip_v"
                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="⇕ Flip V"
                    android:textColor="#FFFFFF" android:background="#374151" android:textSize="11sp"/>
                <Button android:id="@+id/btn_remove_bg"
                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="🪄 Remove BG"
                    android:textColor="#FFFFFF" android:background="#7B1FA2" android:textSize="10sp"/>
                <Button android:id="@+id/btn_reset"
                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                    android:layout_margin="3dp" android:text="↩ Reset"
                    android:textColor="#FFFFFF" android:background="#C62828" android:textSize="11sp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
