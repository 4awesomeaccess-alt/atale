<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_text_tool_popup"
    android:elevation="4dp"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/brightness_drag_handle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="◈ Opacity  ⠿"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#111827"
        android:padding="4dp"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_brightness_minus"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_seekbar_btn"
            android:gravity="center"
            android:text="−"
            android:textColor="#EF4444"
            android:textSize="18sp"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/seek_brightness"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:max="255"
            android:progress="255"
            android:progressTint="#6366F1"
            android:thumbTint="#6366F1" />

        <TextView
            android:id="@+id/tv_brightness_val"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="100"
            android:textColor="#111827"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_brightness_plus"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_seekbar_btn"
            android:gravity="center"
            android:text="+"
            android:textColor="#374151"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
