<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_text_tool_popup"
    android:elevation="4dp"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Drag Handle -->
    <TextView
        android:id="@+id/brightness_drag_handle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="◈ Opacity &amp; Move  ⠿"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#111827"
        android:padding="4dp"
        android:layout_marginBottom="8dp" />

    <!-- Opacity Row -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Opacity"
        android:textSize="11sp"
        android:textColor="#6B7280"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/btn_brightness_minus"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_seekbar_btn"
            android:gravity="center"
            android:text="−"
            android:textColor="#EF4444"
            android:textSize="18sp"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/seek_brightness"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:max="255"
            android:progress="255"
            android:progressTint="#6366F1"
            android:thumbTint="#6366F1" />

        <TextView
            android:id="@+id/tv_brightness_val"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="255"
            android:textColor="#111827"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_brightness_plus"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_seekbar_btn"
            android:gravity="center"
            android:text="+"
            android:textColor="#374151"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E5E7EB"
        android:layout_marginBottom="10dp" />

    <!-- Move Speed Row -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Move Speed"
        android:textSize="11sp"
        android:textColor="#6B7280"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <SeekBar
            android:id="@+id/seek_move_speed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:max="20"
            android:progress="5"
            android:progressTint="#10B981"
            android:thumbTint="#10B981" />

        <TextView
            android:id="@+id/tv_move_speed_val"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="5"
            android:textColor="#111827"
            android:textSize="10sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Move Buttons -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Move"
        android:textSize="11sp"
        android:textColor="#6B7280"
        android:layout_marginBottom="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/popup_btn_move_left"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/selector_move_btn"
            android:padding="8dp"
            android:src="@drawable/selector_move_left"
            android:scaleType="fitCenter" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/popup_btn_move_up"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/selector_move_btn"
                android:padding="8dp"
                android:src="@drawable/selector_move_top"
                android:scaleType="fitCenter" />

            <ImageView
                android:id="@+id/popup_btn_move_down"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/selector_move_btn"
                android:padding="8dp"
                android:src="@drawable/selector_move_bottom"
                android:scaleType="fitCenter" />

        </LinearLayout>

        <ImageView
            android:id="@+id/popup_btn_move_right"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/selector_move_btn"
            android:padding="8dp"
            android:src="@drawable/selector_move_right"
            android:scaleType="fitCenter" />

    </LinearLayout>

</LinearLayout>
