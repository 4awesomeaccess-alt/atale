<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="260dp"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:elevation="16dp">

    <!-- ── Drag Title Bar ── -->
    <LinearLayout
        android:id="@+id/prop_drag_handle"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="#2A3439"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⠿ "
            android:textColor="#9CA3AF"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚙ Text Properties"
            android:textColor="#F3F4F6"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/prop_btn_done"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:text="Done ✓"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:background="#4CAF50"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/prop_btn_close"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:text="✕"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:gravity="center"
            android:background="#374151" />

    </LinearLayout>

    <!-- ── Tab Row ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:background="#F3F4F6">

        <TextView
            android:id="@+id/prop_tab_spacing"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Spacing"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="#607D8B" />

        <TextView
            android:id="@+id/prop_tab_transform"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Transform"
            android:textColor="#6B7280"
            android:textSize="9sp"
            android:gravity="center"
            android:background="#F3F4F6" />

        <TextView
            android:id="@+id/prop_tab_effects"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Effects"
            android:textColor="#6B7280"
            android:textSize="9sp"
            android:gravity="center"
            android:background="#F3F4F6" />

        <TextView
            android:id="@+id/prop_tab_layout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Layout"
            android:textColor="#6B7280"
            android:textSize="9sp"
            android:gravity="center"
            android:background="#F3F4F6" />

        <TextView
            android:id="@+id/prop_tab_visual"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Visual"
            android:textColor="#6B7280"
            android:textSize="9sp"
            android:gravity="center"
            android:background="#F3F4F6" />

        <TextView
            android:id="@+id/prop_tab_typo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Typo"
            android:textColor="#6B7280"
            android:textSize="9sp"
            android:gravity="center"
            android:background="#F3F4F6" />

    </LinearLayout>

    <!-- ── Panels (ScrollView) ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── SPACING PANEL ── -->
            <LinearLayout
                android:id="@+id/prop_panel_spacing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:visibility="visible">

                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="48dp" android:layout_height="wrap_content" android:text="Letter" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <TextView android:id="@+id/prop_btn_letter_minus" android:layout_width="22dp" android:layout_height="20dp" android:background="#374151" android:gravity="center" android:text="−" android:textColor="#F3F4F6" android:textSize="13sp" />
                    <SeekBar android:id="@+id/prop_sb_letter_spacing" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginHorizontal="4dp" android:layout_weight="1" android:max="100" android:progress="0" android:progressTint="#607D8B" android:thumbTint="#2A3439" />
                    <TextView android:id="@+id/prop_btn_letter_plus" android:layout_width="22dp" android:layout_height="20dp" android:background="#374151" android:gravity="center" android:text="+" android:textColor="#F3F4F6" android:textSize="13sp" />
                    <TextView android:id="@+id/prop_tv_letter_val" android:layout_width="28dp" android:layout_height="wrap_content" android:gravity="center" android:text="0" android:textColor="#374151" android:textSize="8sp" android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="48dp" android:layout_height="wrap_content" android:text="Line" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <TextView android:id="@+id/prop_btn_line_minus" android:layout_width="22dp" android:layout_height="20dp" android:background="#374151" android:gravity="center" android:text="−" android:textColor="#F3F4F6" android:textSize="13sp" />
                    <SeekBar android:id="@+id/prop_sb_line_spacing" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginHorizontal="4dp" android:layout_weight="1" android:max="100" android:progress="50" android:progressTint="#607D8B" android:thumbTint="#2A3439" />
                    <TextView android:id="@+id/prop_btn_line_plus" android:layout_width="22dp" android:layout_height="20dp" android:background="#374151" android:gravity="center" android:text="+" android:textColor="#F3F4F6" android:textSize="13sp" />
                    <TextView android:id="@+id/prop_tv_line_val" android:layout_width="28dp" android:layout_height="wrap_content" android:gravity="center" android:text="1.0" android:textColor="#374151" android:textSize="8sp" android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="48dp" android:layout_height="wrap_content" android:text="Pad X" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <TextView android:id="@+id/prop_btn_pad_x_minus" android:layout_width="22dp" android:layout_height="20dp" android:background="#374151" android:gravity="center" android:text="−" android:textColor="#F3F4F6" android:textSize="13sp" />
                    <SeekBar android:id="@+id/prop_sb_pad_x" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginHorizontal="4dp" android:layout_weight="1" android:max="60" android:progress="10" android:progressTint="#607D8B" android:thumbTint="#2A3439" />
                    <TextView android:id="@+id/prop_btn_pad_x_plus" android:layout_width="22dp" android:layout_height="20dp" android:background="#374151" android:gravity="center" android:text="+" android:textColor="#F3F4F6" android:textSize="13sp" />
                    <TextView android:id="@+id/prop_tv_pad_x_val" android:layout_width="28dp" android:layout_height="wrap_content" android:gravity="center" android:text="10" android:textColor="#374151" android:textSize="8sp" android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="48dp" android:layout_height="wrap_content" android:text="Pad Y" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <TextView android:id="@+id/prop_btn_pad_y_minus" android:layout_width="22dp" android:layout_height="20dp" android:background="#374151" android:gravity="center" android:text="−" android:textColor="#F3F4F6" android:textSize="13sp" />
                    <SeekBar android:id="@+id/prop_sb_pad_y" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginHorizontal="4dp" android:layout_weight="1" android:max="60" android:progress="10" android:progressTint="#607D8B" android:thumbTint="#2A3439" />
                    <TextView android:id="@+id/prop_btn_pad_y_plus" android:layout_width="22dp" android:layout_height="20dp" android:background="#374151" android:gravity="center" android:text="+" android:textColor="#F3F4F6" android:textSize="13sp" />
                    <TextView android:id="@+id/prop_tv_pad_y_val" android:layout_width="28dp" android:layout_height="wrap_content" android:gravity="center" android:text="10" android:textColor="#374151" android:textSize="8sp" android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

            <!-- ── TRANSFORM PANEL ── -->
            <LinearLayout
                android:id="@+id/prop_panel_transform"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:visibility="gone">

                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="52dp" android:layout_height="wrap_content" android:text="Rotate" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <TextView android:id="@+id/prop_btn_rotation_minus" android:layout_width="22dp" android:layout_height="20dp" android:background="#374151" android:gravity="center" android:text="−" android:textColor="#F3F4F6" android:textSize="13sp" />
                    <SeekBar android:id="@+id/prop_seek_rotation" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginHorizontal="4dp" android:layout_weight="1" android:max="360" android:progress="180" android:progressTint="#607D8B" android:thumbTint="#2A3439" />
                    <TextView android:id="@+id/prop_btn_rotation_plus" android:layout_width="22dp" android:layout_height="20dp" android:background="#374151" android:gravity="center" android:text="+" android:textColor="#F3F4F6" android:textSize="13sp" />
                    <TextView android:id="@+id/prop_tv_rotation_val" android:layout_width="28dp" android:layout_height="wrap_content" android:gravity="center" android:text="0°" android:textColor="#374151" android:textSize="8sp" android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="52dp" android:layout_height="wrap_content" android:text="Scale X" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <SeekBar android:id="@+id/prop_seek_scale_x" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginHorizontal="4dp" android:layout_weight="1" android:max="200" android:progress="100" android:progressTint="#607D8B" android:thumbTint="#2A3439" />
                    <TextView android:id="@+id/prop_tv_scale_x_val" android:layout_width="30dp" android:layout_height="wrap_content" android:gravity="center" android:text="1.0x" android:textColor="#374151" android:textSize="8sp" android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="52dp" android:layout_height="wrap_content" android:text="Scale Y" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <SeekBar android:id="@+id/prop_seek_scale_y" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginHorizontal="4dp" android:layout_weight="1" android:max="200" android:progress="100" android:progressTint="#607D8B" android:thumbTint="#2A3439" />
                    <TextView android:id="@+id/prop_tv_scale_y_val" android:layout_width="30dp" android:layout_height="wrap_content" android:gravity="center" android:text="1.0x" android:textColor="#374151" android:textSize="8sp" android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="52dp" android:layout_height="wrap_content" android:text="Opacity" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <TextView android:id="@+id/prop_btn_opacity_minus" android:layout_width="22dp" android:layout_height="20dp" android:background="#374151" android:gravity="center" android:text="−" android:textColor="#F3F4F6" android:textSize="13sp" />
                    <SeekBar android:id="@+id/prop_seek_opacity" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginHorizontal="4dp" android:layout_weight="1" android:max="100" android:progress="100" android:progressTint="#607D8B" android:thumbTint="#2A3439" />
                    <TextView android:id="@+id/prop_btn_opacity_plus" android:layout_width="22dp" android:layout_height="20dp" android:background="#374151" android:gravity="center" android:text="+" android:textColor="#F3F4F6" android:textSize="13sp" />
                    <TextView android:id="@+id/prop_tv_opacity_val" android:layout_width="30dp" android:layout_height="wrap_content" android:gravity="center" android:text="100%" android:textColor="#374151" android:textSize="8sp" android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

            <!-- ── EFFECTS PANEL ── -->
            <LinearLayout
                android:id="@+id/prop_panel_effects"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:visibility="gone">

                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="56dp" android:layout_height="wrap_content" android:text="Shadow" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <SeekBar android:id="@+id/prop_sb_shadow_radius" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginHorizontal="4dp" android:layout_weight="1" android:max="30" android:progress="0" android:progressTint="#607D8B" android:thumbTint="#2A3439" />
                    <TextView android:id="@+id/prop_tv_shadow_val" android:layout_width="28dp" android:layout_height="wrap_content" android:gravity="center" android:text="0" android:textColor="#374151" android:textSize="8sp" android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="56dp" android:layout_height="wrap_content" android:text="Shadow X" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <SeekBar android:id="@+id/prop_seek_shadow_dx" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginHorizontal="4dp" android:layout_weight="1" android:max="50" android:progress="25" android:progressTint="#607D8B" android:thumbTint="#2A3439" />
                    <TextView android:id="@+id/prop_tv_shadow_dx_val" android:layout_width="28dp" android:layout_height="wrap_content" android:gravity="center" android:text="0" android:textColor="#374151" android:textSize="8sp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="56dp" android:layout_height="wrap_content" android:text="Shadow Y" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <SeekBar android:id="@+id/prop_seek_shadow_dy" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginHorizontal="4dp" android:layout_weight="1" android:max="50" android:progress="25" android:progressTint="#607D8B" android:thumbTint="#2A3439" />
                    <TextView android:id="@+id/prop_tv_shadow_dy_val" android:layout_width="28dp" android:layout_height="wrap_content" android:gravity="center" android:text="0" android:textColor="#374151" android:textSize="8sp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="56dp" android:layout_height="wrap_content" android:text="Color" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <TextView android:id="@+id/prop_btn_shadow_color" android:layout_width="0dp" android:layout_height="22dp" android:layout_weight="1" android:background="#607D8B" android:gravity="center" android:text="Pick Shadow Color" android:textColor="#FFFFFF" android:textSize="8sp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="56dp" android:layout_height="wrap_content" android:text="Highlight" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <TextView android:id="@+id/prop_btn_highlight_color" android:layout_width="0dp" android:layout_height="22dp" android:layout_weight="1" android:background="#607D8B" android:gravity="center" android:text="Pick Highlight Color" android:textColor="#FFFFFF" android:textSize="8sp" />
                </LinearLayout>

            </LinearLayout>

            <!-- ── LAYOUT PANEL ── -->
            <LinearLayout
                android:id="@+id/prop_panel_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:visibility="gone">

                <!-- Move -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal" android:layout_marginBottom="4dp">
                    <TextView android:id="@+id/prop_btn_sel_left" android:layout_width="0dp" android:layout_height="24dp" android:layout_marginEnd="3dp" android:layout_weight="1" android:background="#374151" android:gravity="center" android:text="◀" android:textColor="#F3F4F6" android:textSize="11sp" />
                    <TextView android:id="@+id/prop_btn_sel_up" android:layout_width="0dp" android:layout_height="24dp" android:layout_marginEnd="3dp" android:layout_weight="1" android:background="#374151" android:gravity="center" android:text="▲" android:textColor="#F3F4F6" android:textSize="11sp" />
                    <TextView android:id="@+id/prop_btn_sel_down" android:layout_width="0dp" android:layout_height="24dp" android:layout_marginEnd="3dp" android:layout_weight="1" android:background="#374151" android:gravity="center" android:text="▼" android:textColor="#F3F4F6" android:textSize="11sp" />
                    <TextView android:id="@+id/prop_btn_sel_right" android:layout_width="0dp" android:layout_height="24dp" android:layout_weight="1" android:background="#374151" android:gravity="center" android:text="▶" android:textColor="#F3F4F6" android:textSize="11sp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="52dp" android:layout_height="wrap_content" android:text="Corner" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <SeekBar android:id="@+id/prop_seek_corner_radius" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginHorizontal="4dp" android:layout_weight="1" android:max="60" android:progress="0" android:progressTint="#607D8B" android:thumbTint="#2A3439" />
                    <TextView android:id="@+id/prop_tv_corner_val" android:layout_width="28dp" android:layout_height="wrap_content" android:gravity="center" android:text="0" android:textColor="#374151" android:textSize="8sp" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
            <!-- ── VISUAL PANEL ── -->
            <LinearLayout
                android:id="@+id/prop_panel_visual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:visibility="gone">

                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="56dp" android:layout_height="wrap_content" android:text="Outline W" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <SeekBar android:id="@+id/prop_sb_outline_width" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginHorizontal="4dp" android:layout_weight="1" android:max="30" android:progress="0" android:progressTint="#607D8B" android:thumbTint="#2A3439" />
                    <TextView android:id="@+id/prop_tv_outline_width" android:layout_width="28dp" android:layout_height="wrap_content" android:gravity="center" android:text="0" android:textColor="#374151" android:textSize="8sp" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="56dp" android:layout_height="wrap_content" android:text="Outline C" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <TextView android:id="@+id/prop_btn_outline_color" android:layout_width="0dp" android:layout_height="22dp" android:layout_weight="1" android:background="#FFFFFF" android:gravity="center" android:text="Pick Outline Color" android:textColor="#374151" android:textSize="8sp" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="56dp" android:layout_height="wrap_content" android:text="Glow" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <SeekBar android:id="@+id/prop_sb_glow" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginHorizontal="4dp" android:layout_weight="1" android:max="40" android:progress="0" android:progressTint="#607D8B" android:thumbTint="#2A3439" />
                    <TextView android:id="@+id/prop_tv_glow" android:layout_width="28dp" android:layout_height="wrap_content" android:gravity="center" android:text="0" android:textColor="#374151" android:textSize="8sp" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="56dp" android:layout_height="wrap_content" android:text="Glow C" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <TextView android:id="@+id/prop_btn_glow_color" android:layout_width="0dp" android:layout_height="22dp" android:layout_weight="1" android:background="#FFFFFF" android:gravity="center" android:text="Pick Glow Color" android:textColor="#374151" android:textSize="8sp" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="56dp" android:layout_height="wrap_content" android:text="3D Depth" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <SeekBar android:id="@+id/prop_sb_3d_depth" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginHorizontal="4dp" android:layout_weight="1" android:max="20" android:progress="0" android:progressTint="#607D8B" android:thumbTint="#2A3439" />
                    <TextView android:id="@+id/prop_tv_3d_depth" android:layout_width="28dp" android:layout_height="wrap_content" android:gravity="center" android:text="0" android:textColor="#374151" android:textSize="8sp" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="56dp" android:layout_height="wrap_content" android:text="BG Opacity" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <SeekBar android:id="@+id/prop_sb_bg_opacity" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginHorizontal="4dp" android:layout_weight="1" android:max="100" android:progress="100" android:progressTint="#607D8B" android:thumbTint="#2A3439" />
                    <TextView android:id="@+id/prop_tv_bg_opacity" android:layout_width="28dp" android:layout_height="wrap_content" android:gravity="center" android:text="100%" android:textColor="#374151" android:textSize="8sp" />
                </LinearLayout>

            </LinearLayout>

            <!-- ── TYPOGRAPHY PANEL ── -->
            <LinearLayout
                android:id="@+id/prop_panel_typo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:visibility="gone">

                <!-- Font Weight -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="56dp" android:layout_height="wrap_content" android:text="Weight" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <SeekBar android:id="@+id/prop_sb_font_weight" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginHorizontal="4dp" android:layout_weight="1" android:max="8" android:progress="3" android:progressTint="#607D8B" android:thumbTint="#2A3439" />
                    <TextView android:id="@+id/prop_tv_font_weight" android:layout_width="28dp" android:layout_height="wrap_content" android:gravity="center" android:text="400" android:textColor="#374151" android:textSize="8sp" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <!-- Text Case -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="56dp" android:layout_height="wrap_content" android:text="Case" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <TextView android:id="@+id/prop_btn_case_normal" android:layout_width="0dp" android:layout_height="22dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="#607D8B" android:gravity="center" android:text="Aa" android:textColor="#FFFFFF" android:textSize="9sp" />
                    <TextView android:id="@+id/prop_btn_case_upper" android:layout_width="0dp" android:layout_height="22dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="#374151" android:gravity="center" android:text="AA" android:textColor="#FFFFFF" android:textSize="9sp" />
                    <TextView android:id="@+id/prop_btn_case_lower" android:layout_width="0dp" android:layout_height="22dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="#374151" android:gravity="center" android:text="aa" android:textColor="#FFFFFF" android:textSize="9sp" />
                    <TextView android:id="@+id/prop_btn_case_title" android:layout_width="0dp" android:layout_height="22dp" android:layout_weight="1" android:background="#374151" android:gravity="center" android:text="Aa Bb" android:textColor="#FFFFFF" android:textSize="8sp" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <!-- Skew -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="56dp" android:layout_height="wrap_content" android:text="Skew X" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <SeekBar android:id="@+id/prop_sb_skew_x" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginHorizontal="4dp" android:layout_weight="1" android:max="100" android:progress="50" android:progressTint="#607D8B" android:thumbTint="#2A3439" />
                    <TextView android:id="@+id/prop_tv_skew_x" android:layout_width="28dp" android:layout_height="wrap_content" android:gravity="center" android:text="0" android:textColor="#374151" android:textSize="8sp" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <!-- Toggle buttons -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:id="@+id/prop_btn_overline" android:layout_width="0dp" android:layout_height="22dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="#374151" android:gravity="center" android:text="T̄ Over" android:textColor="#FFFFFF" android:textSize="9sp" />
                    <TextView android:id="@+id/prop_btn_super" android:layout_width="0dp" android:layout_height="22dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="#374151" android:gravity="center" android:text="T² Super" android:textColor="#FFFFFF" android:textSize="9sp" />
                    <TextView android:id="@+id/prop_btn_sub" android:layout_width="0dp" android:layout_height="22dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="#374151" android:gravity="center" android:text="T₂ Sub" android:textColor="#FFFFFF" android:textSize="9sp" />
                    <TextView android:id="@+id/prop_btn_mirror_h" android:layout_width="0dp" android:layout_height="22dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="#374151" android:gravity="center" android:text="⇔ Mir" android:textColor="#FFFFFF" android:textSize="9sp" />
                    <TextView android:id="@+id/prop_btn_wave" android:layout_width="0dp" android:layout_height="22dp" android:layout_weight="1" android:background="#374151" android:gravity="center" android:text="〜Wave" android:textColor="#FFFFFF" android:textSize="9sp" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <!-- Wave Amplitude -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="56dp" android:layout_height="wrap_content" android:text="Wave Amp" android:textColor="#6B7280" android:textSize="8sp" android:textStyle="bold" />
                    <SeekBar android:id="@+id/prop_sb_wave_amp" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginHorizontal="4dp" android:layout_weight="1" android:max="60" android:progress="20" android:progressTint="#607D8B" android:thumbTint="#2A3439" />
                    <TextView android:id="@+id/prop_tv_wave_amp" android:layout_width="28dp" android:layout_height="wrap_content" android:gravity="center" android:text="20" android:textColor="#374151" android:textSize="8sp" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#D1D5DB" />

                <!-- Auto Fit + Width/Height -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="30dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:id="@+id/prop_btn_auto_fit" android:layout_width="0dp" android:layout_height="22dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="#374151" android:gravity="center" android:text="⬜ AutoFit" android:textColor="#FFFFFF" android:textSize="9sp" />
                    <TextView android:id="@+id/prop_btn_mirror_v" android:layout_width="0dp" android:layout_height="22dp" android:layout_weight="1" android:background="#374151" android:gravity="center" android:text="⇕ Flip V" android:textColor="#FFFFFF" android:textSize="9sp" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
