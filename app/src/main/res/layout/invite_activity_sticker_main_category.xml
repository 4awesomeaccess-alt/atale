<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:background="#DCDCDC"
   >

    <LinearLayout
        android:id="@+id/top_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="20dp"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="32dp"
        android:orientation="horizontal">
        <ImageView
            android:id="@+id/back"
            android:padding="@dimen/_5sdp"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="@dimen/_10dp"
            android:src="@drawable/ic_back"
            app:tint="@color/primary_dark"
            />
<!-- android:src="@drawable/invite_back"-->
        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/roboto_reg"
                android:text="Search Graphic &amp; Caligraphy"
                android:textColor="@color/primary_dark"
                android:textSize="20sp"
                android:letterSpacing="0.01"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/roboto_reg"
                android:text="અહીંથી તમે તમારી પસંદનું Graphic Search કરી શકો છો"
                android:textColor="@color/primary_dark"
                android:textSize="12sp" />

        </LinearLayout>



    </LinearLayout>

    <!-- ═══════════════════════════════════════════
         SEARCH BOX — Soft rose tint background
    ═══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/top_name"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_search_box"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="6dp"
        android:elevation="3dp">

        <ImageView
            android:id="@+id/imgSearch"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="12dp"
            android:src="@drawable/ic_search"
            app:tint="@color/primary_dark" />

        <EditText
            android:id="@+id/search_text"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Search Categories"
            android:inputType="text"
            android:paddingEnd="8dp"
            android:textColor="#3A1A1D"
            android:textColorHint="#B08890"
            android:textSize="15sp"
            android:fontFamily="@font/roboto_reg" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════════
         DIVIDER — Thin maroon accent line
    ═══════════════════════════════════════════ -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1.5dp"
        android:layout_below="@+id/top"
        android:layout_marginTop="2dp"
        android:background="#3F68494A" />

    <!-- ═══════════════════════════════════════════
         TAB LAYOUT — White card with maroon active tab
    ═══════════════════════════════════════════ -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_below="@+id/divider"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_tab_card"
        android:elevation="2dp"
        app:tabMode="fixed"
        app:tabIndicatorHeight="0dp"
        app:tabSelectedTextColor="@color/white"
        app:tabTextColor="#5C1A1E"
        app:tabRippleColor="@android:color/transparent" />

    <!-- ═══════════════════════════════════════════
         VIEW PAGER — Full remaining height
    ═══════════════════════════════════════════ -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/tabLayout"
        android:layout_marginTop="10dp" />

</RelativeLayout>
