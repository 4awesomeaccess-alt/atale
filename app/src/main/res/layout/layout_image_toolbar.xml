<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@android:color/darker_gray"
    android:orientation="vertical"
    android:padding="5dp">
        <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btn_pop_delete"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:backgroundTint="#FF0000"
            android:src="@drawable/ic_delete"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/btn_pop_replace_sticker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/invite_background_2_border_black_extra"
            android:gravity="center"
            android:padding="8dp"
            android:text="🔄\nReplace"
            android:textColor="#1A237E"
            android:textSize="10sp" />


            <TextView
                android:id="@+id/btnSelectPhoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/invite_background_2_border_black_extra"
                android:gravity="center"
                android:padding="8dp"
                android:text="🔄\nphoto select"
                android:textColor="#1A237E"
                android:textSize="10sp" />


        <TextView
            android:id="@+id/btn_pop_frame_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/invite_background_2_border_black_extra"
            android:gravity="center"
            android:padding="8dp"
            android:text="🎨\nColor"
            android:textColor="#1A237E"
            android:textSize="10sp"
            android:visibility="gone" />



        <TextView
            android:id="@+id/btn_pop_select_photo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/invite_background_2_border_black_extra"
            android:gravity="center"
            android:padding="8dp"
            android:text="📷\nPhoto"
            android:textColor="#1A237E"
            android:textSize="10sp"
            android:visibility="gone" />

        <!-- layout_image_toolbar.xml -->
        <ImageView
            android:id="@+id/btn_pop_crop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/invite_background_2_border_black_extra"
            android:gravity="center"
            android:padding="8dp"
            android:text="✂️\nCrop"
            android:src="@drawable/ic_cutnew"
            android:textColor="#1A237E"
            android:textSize="10sp" />

        <ImageView
            android:id="@+id/btn_pop_freehand_crop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/invite_background_2_border_black_extra"
            android:gravity="center"
            android:padding="8dp"
            android:src="@drawable/ic_cutnew"
            android:text="✂️\nCrop"
            android:textColor="#1A237E"
            android:textSize="10sp" />
        <!-- બંને toolbar XML માં ઉમેરો -->
        <TextView
            android:id="@+id/btn_pop_lock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔓\nLock"
            android:gravity="center"
            android:textSize="10sp"
            android:padding="8dp"
            android:textColor="#1A237E"
            android:background="@drawable/invite_background_2_border_black_extra"/>



    </LinearLayout>


</LinearLayout>