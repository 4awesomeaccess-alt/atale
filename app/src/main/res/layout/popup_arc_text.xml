<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/popup_bg"
    android:elevation="8dp"
    android:orientation="vertical">
    <!--popup_arc_text.xml-->
    <!-- ✅ DRAG HANDLE — aa pakadi ne khecho -->
    <LinearLayout
        android:id="@+id/drag_handle"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="#F0F0F0"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Arc Text"
            android:textColor="#222222"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Arc Toggle button — existing text par arc ON/OFF -->
        <Button
            android:id="@+id/btn_toggle_arc"
            android:layout_width="120dp"
            android:layout_height="36dp"
            android:layout_marginBottom="8dp"
            android:text="⌢ Arc ON"
            android:textSize="13sp" />

        <ImageView
            android:id="@+id/btn_close_popup"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel" />
    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <EditText
            android:id="@+id/et_arc_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Text lakho..." />

        <!-- Angle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Angle"
            android:textColor="#888888"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <SeekBar
                android:id="@+id/sb_arc_angle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_angle_value"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="180°"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Radius -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Radius"
            android:textColor="#888888"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <SeekBar
                android:id="@+id/sb_arc_radius"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_radius_value"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="150"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Arc direction -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_arc_up"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="⌢ Up"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_arc_down"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:alpha="0.4"
                android:text="⌣ Down"
                android:textSize="13sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_arc_done"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Done" />

    </LinearLayout>
</LinearLayout>