<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:orientation="vertical"
    android:background="#2A3439"
    android:elevation="16dp">

    <!-- ── Drag Title Bar ── -->
    <LinearLayout
        android:id="@+id/drag_handle"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="#1C2529"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⠿ "
            android:textColor="#9CA3AF"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⌢ Arc Text"
            android:textColor="#F3F4F6"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Arc Toggle -->
        <Button
            android:id="@+id/btn_toggle_arc"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:text="⌢ Arc ON"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E65100"
            android:stateListAnimator="@null"
            android:layout_marginEnd="4dp"
            android:paddingHorizontal="8dp" />

        <TextView
            android:id="@+id/btn_arc_done"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:text="Done ✓"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:background="#4CAF50"
            android:layout_marginEnd="4dp" />

        <ImageView
            android:id="@+id/btn_close_popup"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:background="#374151"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:padding="5dp" />

    </LinearLayout>

    <!-- ── Content ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:padding="8dp">

        <!-- Left: Text input + Direction -->
        <LinearLayout
            android:layout_width="110dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingEnd="8dp">

            <!-- Text input -->
            <EditText
                android:id="@+id/et_arc_text"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:hint="Text..."
                android:textColor="#FFFFFF"
                android:textColorHint="#6B7280"
                android:textSize="12sp"
                android:background="#374151"
                android:paddingHorizontal="8dp"
                android:layout_marginBottom="6dp" />

            <!-- Direction buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_arc_up"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:text="⌢ Up"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#E65100"
                    android:stateListAnimator="@null"
                    android:layout_marginEnd="3dp" />

                <Button
                    android:id="@+id/btn_arc_down"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:text="⌣ Down"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#607D8B"
                    android:stateListAnimator="@null"
                    android:alpha="0.6" />

            </LinearLayout>

        </LinearLayout>

        <!-- Right: Angle + Radius sliders -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <!-- Angle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Angle"
                android:textColor="#9CA3AF"
                android:textSize="9sp"
                android:layout_marginBottom="2dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <SeekBar
                    android:id="@+id/sb_arc_angle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="360"
                    android:progress="180"
                    android:progressTint="#E65100"
                    android:thumbTint="#CFD8DC" />

                <TextView
                    android:id="@+id/tv_angle_value"
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="180°"
                    android:textColor="#CFD8DC"
                    android:textSize="9sp"
                    android:gravity="end"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <!-- Radius -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Radius"
                android:textColor="#9CA3AF"
                android:textSize="9sp"
                android:layout_marginBottom="2dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <SeekBar
                    android:id="@+id/sb_arc_radius"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="500"
                    android:progress="150"
                    android:progressTint="#4CAF50"
                    android:thumbTint="#CFD8DC" />

                <TextView
                    android:id="@+id/tv_radius_value"
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="150"
                    android:textColor="#CFD8DC"
                    android:textSize="9sp"
                    android:gravity="end"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
