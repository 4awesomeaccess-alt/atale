<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/gp_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_text_tool_popup"
    android:clipToOutline="true">

    <!-- ── Drag Handle ── -->
    <LinearLayout
        android:id="@+id/gp_drag_handle"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:background="#F3F4F6"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⠿ "
            android:textColor="#9CA3AF"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎨 Background Color"
            android:textColor="#111827"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/gp_btn_close"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:text="✕"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:gravity="center"
            android:background="#EF4444" />

        <TextView
            android:id="@+id/gp_btn_done"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:text="Done ✓"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:background="#4CAF50"
            android:layout_marginStart="6dp" />

    </LinearLayout>

    <!-- ── Tab Row: Solid / Gradient / Shape / None ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_tabs_container"
        android:padding="4dp"
        android:layout_margin="12dp">

        <TextView
            android:id="@+id/gp_tab_solid"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="🎨 Solid"
            android:textColor="#2E7D32"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_tab_active" />

        <TextView
            android:id="@+id/gp_tab_gradient"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="🌈 Gradient"
            android:textColor="#6B7280"
            android:textSize="13sp"
            android:gravity="center"
            android:background="@drawable/bg_tab_inactive" />

        <TextView
            android:id="@+id/gp_tab_gallery"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="🔷 Shape"
            android:textColor="#6B7280"
            android:textSize="13sp"
            android:gravity="center"
            android:background="@drawable/bg_tab_inactive" />

        <TextView
            android:id="@+id/gp_tab_none"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="⃠ None"
            android:textColor="#6B7280"
            android:textSize="13sp"
            android:gravity="center"
            android:background="@drawable/bg_tab_inactive" />

    </LinearLayout>

    <!-- ── Solid Panel ── -->
    <LinearLayout
        android:id="@+id/gp_panel_solid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="visible">

        <!-- Top: Color grid (left) + Hex/OK/Wheel (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Left: Preset color grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/gp_solid_color_grid"
                android:layout_width="0dp"
                android:layout_height="200dp"
                android:layout_weight="0.8"
                android:layout_marginEnd="12dp" />

            <!-- Right: Hex + OK + Color Wheel -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:orientation="vertical">

                <!-- Hex row + OK -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_tabs_container"
                    android:padding="4dp"
                    android:layout_marginBottom="10dp">

                    <View
                        android:id="@+id/gp_solid_hex_preview"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_color_preview"
                        android:layout_marginEnd="6dp" />

                    <EditText
                        android:id="@+id/gp_solid_et_hex"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="#000000"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"
                        android:textSize="14sp"
                        android:background="@android:color/transparent"
                        android:inputType="text"
                        android:maxLength="7"
                        android:singleLine="true"
                        android:imeOptions="actionDone" />

                    <TextView
                        android:id="@+id/gp_solid_btn_ok"
                        android:layout_width="44dp"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="OK"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_continue_btn" />

                </LinearLayout>

                <!-- Color Wheel -->
                <com.example.newcardmaker.ColorWheelView
                    android:id="@+id/gp_solid_wheel"
                    android:layout_width="match_parent"
                    android:layout_height="150dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Bottom: Full width Opacity SeekBar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_tabs_container"
            android:padding="10dp"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/gp_opacity_minus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="−"
                android:textSize="20sp"
                android:textColor="#EF4444"
                android:background="@drawable/bg_seekbar_btn" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Opacity:- "
                android:textSize="13sp"
                android:textColor="#374151"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/gp_opacity_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="05"
                android:textSize="13sp"
                android:textColor="#374151"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />

            <SeekBar
                android:id="@+id/gp_solid_opacity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="255"
                android:progress="255"
                android:progressTint="#EF9A9A"
                android:thumbTint="#FFFFFF" />

            <TextView
                android:id="@+id/gp_opacity_plus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="+"
                android:textSize="20sp"
                android:textColor="#374151"
                android:background="@drawable/bg_seekbar_btn"
                android:layout_marginStart="8dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── Gradient Panel ── -->
    <LinearLayout
        android:id="@+id/gp_panel_gradient"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone">

        <!-- Gradient Preview (live) -->
        <View
            android:id="@+id/gp_gradient_preview"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:background="@drawable/bg_color_preview"
            android:layout_marginBottom="6dp" />

        <!-- Color 1 / Color 2 selectable tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <LinearLayout
                android:id="@+id/gp_color1_tab"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_tab_active"
                android:padding="6dp"
                android:layout_marginEnd="6dp">

                <View
                    android:id="@+id/gp_color1_box"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_color_preview"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Color 1"
                    android:textColor="#2E7D32"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/gp_color2_tab"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_tab_inactive"
                android:padding="6dp">

                <View
                    android:id="@+id/gp_color2_box"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_color_preview"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Color 2"
                    android:textColor="#6B7280"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- Hidden hex inputs (kept for Java compatibility) -->
        <EditText
            android:id="@+id/gp_color1_hex"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:text="FF0000" />
        <EditText
            android:id="@+id/gp_color2_hex"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:text="0000FF" />

        <!-- Color Wheel (applies to selected color tab) -->
        <com.example.newcardmaker.ColorWheelView
            android:id="@+id/gp_grad_wheel"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_marginBottom="6dp" />

        <!-- Direction Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Direction:"
                android:textColor="#374151"
                android:textSize="12sp"
                android:layout_marginEnd="8dp" />

            <TextView android:id="@+id/gp_dir_lr" android:layout_width="0dp" android:layout_weight="1" android:layout_height="30dp" android:text="→" android:textColor="#FFFFFF" android:textSize="14sp" android:gravity="center" android:background="@drawable/bg_tab_active" android:layout_marginEnd="4dp" />
            <TextView android:id="@+id/gp_dir_tb" android:layout_width="0dp" android:layout_weight="1" android:layout_height="30dp" android:text="↓" android:textColor="#6B7280" android:textSize="14sp" android:gravity="center" android:background="@drawable/bg_tab_inactive" android:layout_marginEnd="4dp" />
            <TextView android:id="@+id/gp_dir_diag" android:layout_width="0dp" android:layout_weight="1" android:layout_height="30dp" android:text="↘" android:textColor="#6B7280" android:textSize="14sp" android:gravity="center" android:background="@drawable/bg_tab_inactive" android:layout_marginEnd="4dp" />
            <TextView android:id="@+id/gp_dir_rad" android:layout_width="0dp" android:layout_weight="1" android:layout_height="30dp" android:text="◎" android:textColor="#6B7280" android:textSize="14sp" android:gravity="center" android:background="@drawable/bg_tab_inactive" />

        </LinearLayout>

        <!-- Apply gradient button -->
        <TextView
            android:id="@+id/gp_gradient_apply"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="Apply Gradient"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_continue_btn"
            android:layout_marginBottom="6dp" />

        <!-- Gradient Opacity -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Opacity:"
                android:textColor="#374151"
                android:textSize="12sp"
                android:layout_marginEnd="6dp" />

            <SeekBar
                android:id="@+id/gp_grad_opacity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="255"
                android:progress="255"
                android:progressTint="#EF9A9A"
                android:thumbTint="#FFFFFF" />

            <TextView
                android:id="@+id/gp_grad_opacity_val"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="255"
                android:textColor="#374151"
                android:textSize="11sp"
                android:gravity="end"
                android:layout_marginStart="4dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── Image Panel ── -->
    <LinearLayout
        android:id="@+id/gp_panel_image"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:padding="6dp"
        android:visibility="gone">

        <!-- LEFT: Image preview + Select/Remove buttons -->
        <LinearLayout
            android:layout_width="110dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingEnd="6dp">

            <!-- Image preview -->
            <ImageView
                android:id="@+id/gp_image_preview"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scaleType="centerCrop"
                android:background="#F3F4F6"
                android:layout_marginBottom="4dp" />

            <!-- Select + Remove buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/gp_image_pick"
                    android:layout_width="0dp"
                    android:layout_height="26dp"
                    android:layout_weight="1"
                    android:text="📷"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:background="#1565C0"
                    android:layout_marginEnd="3dp" />

                <TextView
                    android:id="@+id/gp_image_remove"
                    android:layout_width="0dp"
                    android:layout_height="26dp"
                    android:layout_weight="1"
                    android:text="✕"
                    android:textColor="#111827"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="#B71C1C" />

            </LinearLayout>

        </LinearLayout>

        <!-- RIGHT: Tint — Color Wheel + Opacity -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="4dp">

            <!-- Tint preview + HEX + Remove -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <View
                    android:id="@+id/gp_tint_preview"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="#00000000"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#"
                    android:textColor="#9CA3AF"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/gp_tint_et_hex"
                    android:layout_width="0dp"
                    android:layout_height="26dp"
                    android:layout_weight="1"
                    android:hint="FF0000"
                    android:textColor="#111827"
                    android:textColorHint="#6B7280"
                    android:textSize="10sp"
                    android:background="#F3F4F6"
                    android:paddingHorizontal="4dp"
                    android:inputType="text"
                    android:maxLength="6"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/gp_tint_none"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:text="✕"
                    android:textColor="#111827"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:background="#B71C1C"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <!-- Color Wheel -->
            <com.example.newcardmaker.ColorWheelView
                android:id="@+id/gp_tint_wheel"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp" />

            <!-- Opacity -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Opacity:"
                    android:textColor="#9CA3AF"
                    android:textSize="9sp"
                    android:layout_marginEnd="4dp" />

                <SeekBar
                    android:id="@+id/gp_tint_opacity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="255"
                    android:progress="255"
                    android:progressTint="#607D8B"
                    android:thumbTint="#CFD8DC" />

                <TextView
                    android:id="@+id/gp_tint_opacity_val"
                    android:layout_width="28dp"
                    android:layout_height="wrap_content"
                    android:text="255"
                    android:textColor="#CFD8DC"
                    android:textSize="9sp"
                    android:gravity="end"
                    android:layout_marginStart="3dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ── Gallery Panel ── -->
    <LinearLayout
        android:id="@+id/gp_panel_gallery"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="8dp">

        <!-- Gallery button -->
        <LinearLayout
            android:id="@+id/gp_gallery_open"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_lang_btn"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📷  Gallery માંથી image select"
                android:textSize="13sp"
                android:textColor="#1565C0"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/gp_brush_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <!-- Brush image grid -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/gp_brush_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Color row (after image select) -->
        <LinearLayout
            android:id="@+id/gp_img_color_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/gp_btn_show_images"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="← Images"
                android:textColor="#1565C0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_lang_btn"
                android:layout_marginBottom="6dp" />

            <ImageView
                android:id="@+id/gp_img_preview"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:scaleType="centerCrop"
                android:layout_marginBottom="8dp" />

            <!-- Color Wheel + Pick Color button row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <com.example.newcardmaker.ColorWheelView
                    android:id="@+id/gp_img_tint_wheel"
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/gp_btn_pick_color"
                    android:layout_width="70dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="🎨 Pick"
                    android:textSize="11sp"
                    android:textColor="#1565C0"
                    android:textStyle="bold"
                    android:background="@drawable/bg_lang_btn"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Padding X -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="Pad X"
                    android:textSize="11sp"
                    android:textColor="#374151" />

                <TextView
                    android:id="@+id/gp_pad_x_minus"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:text="−"
                    android:textColor="#EF4444"
                    android:textSize="16sp"
                    android:background="@drawable/bg_seekbar_btn" />

                <SeekBar
                    android:id="@+id/gp_seek_pad_x"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#1565C0"
                    android:thumbTint="#1565C0" />

                <TextView
                    android:id="@+id/gp_pad_x_plus"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="#374151"
                    android:textSize="16sp"
                    android:background="@drawable/bg_seekbar_btn" />

                <TextView
                    android:id="@+id/gp_pad_x_val"
                    android:layout_width="30dp"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="11sp"
                    android:textColor="#374151"
                    android:gravity="center" />

            </LinearLayout>

            <!-- Padding Y -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="Pad Y"
                    android:textSize="11sp"
                    android:textColor="#374151" />

                <TextView
                    android:id="@+id/gp_pad_y_minus"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:text="−"
                    android:textColor="#EF4444"
                    android:textSize="16sp"
                    android:background="@drawable/bg_seekbar_btn" />

                <SeekBar
                    android:id="@+id/gp_seek_pad_y"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#1565C0"
                    android:thumbTint="#1565C0" />

                <TextView
                    android:id="@+id/gp_pad_y_plus"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="#374151"
                    android:textSize="16sp"
                    android:background="@drawable/bg_seekbar_btn" />

                <TextView
                    android:id="@+id/gp_pad_y_val"
                    android:layout_width="30dp"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="11sp"
                    android:textColor="#374151"
                    android:gravity="center" />

            </LinearLayout>

            <TextView
                android:id="@+id/gp_btn_img_apply"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="Apply"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_continue_btn" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
