<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/gp_root"
    android:layout_width="match_parent"
    android:layout_height="230dp"
    android:orientation="vertical"
    android:background="#2A3439"
    android:elevation="16dp">

    <!-- ── Drag Handle ── -->
    <LinearLayout
        android:id="@+id/gp_drag_handle"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:background="#1C2529"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⠿ "
            android:textColor="#9CA3AF"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎨 Background Color"
            android:textColor="#F3F4F6"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/gp_btn_close"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:text="✕"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:gravity="center"
            android:background="#374151" />

        <TextView
            android:id="@+id/gp_btn_done"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:text="Done ✓"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:background="#4CAF50"
            android:layout_marginStart="6dp" />

    </LinearLayout>

    <!-- ── Tab Row: Solid / Gradient ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:orientation="horizontal"
        android:background="#1C2529">

        <TextView
            android:id="@+id/gp_tab_solid"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="⬛ Solid"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="#607D8B" />

        <TextView
            android:id="@+id/gp_tab_gradient"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="🌈 Gradient"
            android:textColor="#9CA3AF"
            android:textSize="11sp"
            android:gravity="center"
            android:background="#2A3439" />

        <TextView
            android:id="@+id/gp_tab_image"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="🖼 Image"
            android:textColor="#9CA3AF"
            android:textSize="11sp"
            android:gravity="center"
            android:background="#2A3439" />

        <TextView
            android:id="@+id/gp_tab_none"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="✕ None"
            android:textColor="#9CA3AF"
            android:textSize="11sp"
            android:gravity="center"
            android:background="#2A3439" />

    </LinearLayout>

    <!-- ── Solid Panel ── -->
    <LinearLayout
        android:id="@+id/gp_panel_solid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:padding="8dp"
        android:visibility="visible">

        <!-- Left: Color preview + HEX -->
        <LinearLayout
            android:layout_width="80dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingEnd="6dp">

            <View
                android:id="@+id/gp_solid_hex_preview"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="#FF0000"
                android:layout_marginBottom="4dp" />

            <!-- HEX input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="26dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#"
                    android:textColor="#9CA3AF"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/gp_solid_et_hex"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="FF0000"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#6B7280"
                    android:textSize="9sp"
                    android:background="#374151"
                    android:paddingHorizontal="4dp"
                    android:inputType="text"
                    android:maxLength="6"
                    android:singleLine="true"
                    android:imeOptions="actionDone" />

            </LinearLayout>

        </LinearLayout>

        <!-- Right: Color Wheel -->
        <com.example.newcardmaker.ColorWheelView
            android:id="@+id/gp_solid_wheel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- ── Gradient Panel ── -->
    <LinearLayout
        android:id="@+id/gp_panel_gradient"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone">

        <!-- Gradient Preview -->
        <View
            android:id="@+id/gp_gradient_preview"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginBottom="6dp" />

        <!-- Color 1 + Color 2 Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Color 1:"
                android:textColor="#CFD8DC"
                android:textSize="10sp"
                android:layout_marginEnd="4dp" />

            <View
                android:id="@+id/gp_color1_box"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="#FF0000"
                android:layout_marginEnd="6dp" />

            <EditText
                android:id="@+id/gp_color1_hex"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:text="FF0000"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:background="#374151"
                android:paddingHorizontal="4dp"
                android:inputType="text"
                android:maxLength="6"
                android:singleLine="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Color 2:"
                android:textColor="#CFD8DC"
                android:textSize="10sp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="4dp" />

            <View
                android:id="@+id/gp_color2_box"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="#0000FF"
                android:layout_marginEnd="6dp" />

            <EditText
                android:id="@+id/gp_color2_hex"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:text="0000FF"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:background="#374151"
                android:paddingHorizontal="4dp"
                android:inputType="text"
                android:maxLength="6"
                android:singleLine="true" />

        </LinearLayout>

        <!-- Direction Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Direction:"
                android:textColor="#CFD8DC"
                android:textSize="10sp"
                android:layout_marginEnd="6dp" />

            <TextView android:id="@+id/gp_dir_lr" android:layout_width="wrap_content" android:layout_height="26dp" android:text="→" android:textColor="#FFFFFF" android:textSize="13sp" android:gravity="center" android:paddingHorizontal="8dp" android:background="#607D8B" android:layout_marginEnd="4dp" />
            <TextView android:id="@+id/gp_dir_tb" android:layout_width="wrap_content" android:layout_height="26dp" android:text="↓" android:textColor="#9CA3AF" android:textSize="13sp" android:gravity="center" android:paddingHorizontal="8dp" android:background="#374151" android:layout_marginEnd="4dp" />
            <TextView android:id="@+id/gp_dir_diag" android:layout_width="wrap_content" android:layout_height="26dp" android:text="↘" android:textColor="#9CA3AF" android:textSize="13sp" android:gravity="center" android:paddingHorizontal="8dp" android:background="#374151" android:layout_marginEnd="4dp" />
            <TextView android:id="@+id/gp_dir_rad" android:layout_width="wrap_content" android:layout_height="26dp" android:text="◎" android:textColor="#9CA3AF" android:textSize="13sp" android:gravity="center" android:paddingHorizontal="8dp" android:background="#374151" />

        </LinearLayout>

        <!-- Apply gradient button -->
        <TextView
            android:id="@+id/gp_gradient_apply"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:text="✅ Apply Gradient"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:background="#4CAF50" />

    </LinearLayout>

    <!-- ── Image Panel ── -->
    <LinearLayout
        android:id="@+id/gp_panel_image"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:padding="6dp"
        android:visibility="gone">

        <!-- LEFT: Image preview + Select/Remove buttons -->
        <LinearLayout
            android:layout_width="110dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingEnd="6dp">

            <!-- Image preview -->
            <ImageView
                android:id="@+id/gp_image_preview"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scaleType="centerCrop"
                android:background="#374151"
                android:layout_marginBottom="4dp" />

            <!-- Select + Remove buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/gp_image_pick"
                    android:layout_width="0dp"
                    android:layout_height="26dp"
                    android:layout_weight="1"
                    android:text="📷"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:background="#1565C0"
                    android:layout_marginEnd="3dp" />

                <TextView
                    android:id="@+id/gp_image_remove"
                    android:layout_width="0dp"
                    android:layout_height="26dp"
                    android:layout_weight="1"
                    android:text="✕"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="#B71C1C" />

            </LinearLayout>

        </LinearLayout>

        <!-- RIGHT: Tint — Color Wheel + Opacity -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="4dp">

            <!-- Tint preview + HEX + Remove -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <View
                    android:id="@+id/gp_tint_preview"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="#00000000"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#"
                    android:textColor="#9CA3AF"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/gp_tint_et_hex"
                    android:layout_width="0dp"
                    android:layout_height="26dp"
                    android:layout_weight="1"
                    android:hint="FF0000"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#6B7280"
                    android:textSize="10sp"
                    android:background="#374151"
                    android:paddingHorizontal="4dp"
                    android:inputType="text"
                    android:maxLength="6"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/gp_tint_none"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:text="✕"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:background="#B71C1C"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <!-- Color Wheel -->
            <com.example.newcardmaker.ColorWheelView
                android:id="@+id/gp_tint_wheel"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp" />

            <!-- Opacity -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Opacity:"
                    android:textColor="#9CA3AF"
                    android:textSize="9sp"
                    android:layout_marginEnd="4dp" />

                <SeekBar
                    android:id="@+id/gp_tint_opacity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="255"
                    android:progress="255"
                    android:progressTint="#607D8B"
                    android:thumbTint="#CFD8DC" />

                <TextView
                    android:id="@+id/gp_tint_opacity_val"
                    android:layout_width="28dp"
                    android:layout_height="wrap_content"
                    android:text="255"
                    android:textColor="#CFD8DC"
                    android:textSize="9sp"
                    android:gravity="end"
                    android:layout_marginStart="3dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
