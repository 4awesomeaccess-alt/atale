<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111111">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="#1565C0"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Image Crop કરો"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Drag handles to crop"
            android:textColor="#BBDEFB"
            android:textSize="10sp"/>

    </LinearLayout>

    <!-- Aspect Ratio Scroll -->
    <HorizontalScrollView
        android:id="@+id/scroll_aspect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A1A"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/ll_aspect_buttons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"/>

    </HorizontalScrollView>

    <!-- Image + Crop Overlay -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000">

        <ImageView
            android:id="@+id/iv_crop_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"/>

        <com.example.newcardmaker.CropOverlayView
            android:id="@+id/crop_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </FrameLayout>

    <!-- Transform Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1A1A1A"
        android:padding="6dp">

        <Button
            android:id="@+id/btn_rotate_left"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="↺ 90°"
            android:textSize="12sp"
            android:backgroundTint="#333333"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_rotate_right"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="↻ 90°"
            android:textSize="12sp"
            android:backgroundTint="#333333"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_flip_h"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="⇆ Flip H"
            android:textSize="11sp"
            android:backgroundTint="#333333"
            android:textColor="#FFFFFF"
            android:alpha="0.5"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_flip_v"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="⇅ Flip V"
            android:textSize="11sp"
            android:backgroundTint="#333333"
            android:textColor="#FFFFFF"
            android:alpha="0.5"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_crop_reset"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Reset"
            android:textSize="11sp"
            android:backgroundTint="#F57C00"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#111111"
        android:padding="6dp">

        <Button
            android:id="@+id/btn_crop_cancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:backgroundTint="#616161"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_crop_apply"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="2"
            android:text="✅ Crop Apply"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:backgroundTint="#43A047"/>

    </LinearLayout>

</LinearLayout>