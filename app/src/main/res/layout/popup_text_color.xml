<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/popup_root"
    android:layout_width="match_parent"
    android:layout_height="210dp"
    android:orientation="vertical"
    android:background="#2A3439"
    android:elevation="16dp">

    <!-- ── Drag Handle / Title Bar ── -->
    <LinearLayout
        android:id="@+id/tv_color_title"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:orientation="horizontal"
        android:background="#1C2529"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⠿ "
            android:textColor="#6B7280"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎨 Text Color"
            android:textColor="#F3F4F6"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="drag to move"
            android:textColor="#6B7280"
            android:textSize="8sp" />

        <!-- Screen Color Picker button -->
        <TextView
            android:id="@+id/btn_screen_pick"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:text="🖱 Select"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:background="#3F51B5"
            android:layout_marginStart="6dp" />

        <TextView
            android:id="@+id/btn_color_close"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:text="✕"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:gravity="center"
            android:background="#607D8B"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- ── Tab Row: Solid / Gradient ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:orientation="horizontal"
        android:background="#1C2529">

        <TextView
            android:id="@+id/tc_tab_solid"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="⬛ Solid"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="#607D8B" />

        <TextView
            android:id="@+id/tc_tab_gradient"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="🌈 Gradient"
            android:textColor="#9CA3AF"
            android:textSize="10sp"
            android:gravity="center"
            android:background="#2A3439" />

    </LinearLayout>

    <!-- ── Solid Panel ── -->
    <LinearLayout
        android:id="@+id/tc_panel_solid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:padding="8dp"
        android:visibility="visible">

        <!-- Left: Quick Colors + Hex + Buttons -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="6dp">

            <!-- Quick Color Scroll -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:scrollbars="none"
                android:layout_marginBottom="6dp">

                <LinearLayout
                    android:id="@+id/color_row"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical" />

            </HorizontalScrollView>

            <!-- Hex Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <View
                    android:id="@+id/view_hex_preview"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="#FF0000"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#"
                    android:textColor="#9CA3AF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="2dp" />

                <EditText
                    android:id="@+id/et_hex_color"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="FF0000"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#6B7280"
                    android:textSize="11sp"
                    android:background="#374151"
                    android:paddingHorizontal="6dp"
                    android:inputType="text"
                    android:maxLength="6"
                    android:singleLine="true"
                    android:imeOptions="actionDone" />

                <TextView
                    android:id="@+id/btn_hex_apply"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="OK"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:background="#607D8B"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <!-- Cancel / Done -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <TextView
                    android:id="@+id/btn_color_cancel"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="Cancel"
                    android:textColor="#9CA3AF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:paddingHorizontal="10dp" />

                <TextView
                    android:id="@+id/btn_color_done"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="Done ✓"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:paddingHorizontal="10dp"
                    android:background="#4CAF50"
                    android:layout_marginStart="6dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Right: Color Wheel -->
        <com.example.newcardmaker.ColorWheelView
            android:id="@+id/color_wheel"
            android:layout_width="140dp"
            android:layout_height="match_parent" />

    </LinearLayout>

    <!-- ── Gradient Panel ── -->
    <LinearLayout
        android:id="@+id/tc_panel_gradient"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone">

        <!-- Gradient Preview -->
        <View
            android:id="@+id/tc_grad_preview"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_marginBottom="6dp" />

        <!-- Color 1 + Color 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="C1:" android:textColor="#9CA3AF" android:textSize="10sp" android:layout_marginEnd="4dp" />
            <View android:id="@+id/tc_grad_c1_box" android:layout_width="26dp" android:layout_height="26dp" android:background="#FF0000" android:layout_marginEnd="4dp" />
            <EditText android:id="@+id/tc_grad_c1_hex" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:text="FF0000" android:textColor="#FFFFFF" android:textSize="10sp" android:background="#374151" android:paddingHorizontal="4dp" android:inputType="text" android:maxLength="6" android:singleLine="true" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="C2:" android:textColor="#9CA3AF" android:textSize="10sp" android:layout_marginStart="8dp" android:layout_marginEnd="4dp" />
            <View android:id="@+id/tc_grad_c2_box" android:layout_width="26dp" android:layout_height="26dp" android:background="#0000FF" android:layout_marginEnd="4dp" />
            <EditText android:id="@+id/tc_grad_c2_hex" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:text="0000FF" android:textColor="#FFFFFF" android:textSize="10sp" android:background="#374151" android:paddingHorizontal="4dp" android:inputType="text" android:maxLength="6" android:singleLine="true" />

        </LinearLayout>

        <!-- Direction -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dir:" android:textColor="#9CA3AF" android:textSize="10sp" android:layout_marginEnd="6dp" />
            <TextView android:id="@+id/tc_dir_lr" android:layout_width="32dp" android:layout_height="26dp" android:text="→" android:textColor="#FFFFFF" android:textSize="13sp" android:gravity="center" android:background="#607D8B" android:layout_marginEnd="4dp" />
            <TextView android:id="@+id/tc_dir_tb" android:layout_width="32dp" android:layout_height="26dp" android:text="↓" android:textColor="#9CA3AF" android:textSize="13sp" android:gravity="center" android:background="#374151" android:layout_marginEnd="4dp" />
            <TextView android:id="@+id/tc_dir_diag" android:layout_width="32dp" android:layout_height="26dp" android:text="↘" android:textColor="#9CA3AF" android:textSize="13sp" android:gravity="center" android:background="#374151" android:layout_marginEnd="4dp" />

        </LinearLayout>

        <!-- Apply -->
        <TextView
            android:id="@+id/tc_grad_apply"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:text="✅ Apply Gradient"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:gravity="center"
            android:background="#4CAF50" />

    </LinearLayout>

</LinearLayout>
