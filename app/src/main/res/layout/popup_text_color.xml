<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/popup_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#2A3439"
    android:elevation="16dp">

    <!-- ── Drag Handle / Title Bar ── -->
    <LinearLayout
        android:id="@+id/tv_color_title"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:background="#1C2529"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⠿ "
            android:textColor="#6B7280"
            android:textSize="14sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎨 Text Color"
            android:textColor="#F3F4F6"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="drag to move"
            android:textColor="#6B7280"
            android:textSize="9sp" />

    </LinearLayout>

    <!-- ── Content ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

    <!-- ── Preview ── -->
    <TextView
        android:id="@+id/tv_color_preview"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center"
        android:textSize="20sp"
        android:textStyle="bold"
        android:background="#374151"
        android:layout_marginBottom="10dp" />

    <!-- ── Quick Color Scroll Row ── -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="10dp">

        <LinearLayout
            android:id="@+id/color_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="4dp" />

    </HorizontalScrollView>

    <!-- ── Color Wheel ── -->
    <com.example.newcardmaker.ColorWheelView
        android:id="@+id/color_wheel"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginBottom="10dp" />

    <!-- ── Hex Input Row ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <View
            android:id="@+id/view_hex_preview"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="#FF0000"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#"
            android:textColor="#9CA3AF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginEnd="4dp" />

        <EditText
            android:id="@+id/et_hex_color"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:hint="FF0000"
            android:textColor="#FFFFFF"
            android:textColorHint="#6B7280"
            android:textSize="13sp"
            android:background="#374151"
            android:paddingHorizontal="10dp"
            android:inputType="text"
            android:maxLength="6"
            android:singleLine="true"
            android:imeOptions="actionDone" />

        <TextView
            android:id="@+id/btn_hex_apply"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Apply"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:background="#607D8B"
            android:layout_marginStart="6dp" />

    </LinearLayout>

    <!-- ── Cancel / Done Row ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <TextView
            android:id="@+id/btn_color_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="#9CA3AF"
            android:textSize="13sp"
            android:paddingHorizontal="18dp"
            android:paddingVertical="10dp" />

        <TextView
            android:id="@+id/btn_color_done"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Done ✓"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:paddingHorizontal="18dp"
            android:paddingVertical="10dp"
            android:background="#4CAF50"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    </LinearLayout><!-- end content -->

</LinearLayout>
