<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/popup_root"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:orientation="vertical"
    android:background="#2A3439"
    android:elevation="16dp">

    <!-- ── Drag Handle / Title Bar ── -->
    <LinearLayout
        android:id="@+id/tv_color_title"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:orientation="horizontal"
        android:background="#1C2529"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⠿ "
            android:textColor="#6B7280"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎨 Text Color"
            android:textColor="#F3F4F6"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="drag to move"
            android:textColor="#6B7280"
            android:textSize="8sp" />

    </LinearLayout>

    <!-- ── Content (150dp = 180 - 30 title) ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:padding="8dp">

        <!-- Left: Preview + Quick Colors + Hex -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="6dp">

            <!-- Preview -->
            <TextView
                android:id="@+id/tv_color_preview"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="#374151"
                android:layout_marginBottom="6dp" />

            <!-- Quick Color Scroll -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:scrollbars="none"
                android:layout_marginBottom="6dp">

                <LinearLayout
                    android:id="@+id/color_row"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical" />

            </HorizontalScrollView>

            <!-- Hex Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <View
                    android:id="@+id/view_hex_preview"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="#FF0000"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#"
                    android:textColor="#9CA3AF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="2dp" />

                <EditText
                    android:id="@+id/et_hex_color"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="FF0000"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#6B7280"
                    android:textSize="11sp"
                    android:background="#374151"
                    android:paddingHorizontal="6dp"
                    android:inputType="text"
                    android:maxLength="6"
                    android:singleLine="true"
                    android:imeOptions="actionDone" />

                <TextView
                    android:id="@+id/btn_hex_apply"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="OK"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:background="#607D8B"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <!-- Cancel / Done -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <TextView
                    android:id="@+id/btn_color_cancel"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="Cancel"
                    android:textColor="#9CA3AF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:paddingHorizontal="10dp" />

                <TextView
                    android:id="@+id/btn_color_done"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="Done ✓"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:paddingHorizontal="10dp"
                    android:background="#4CAF50"
                    android:layout_marginStart="6dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Right: Color Wheel -->
        <com.example.newcardmaker.ColorWheelView
            android:id="@+id/color_wheel"
            android:layout_width="140dp"
            android:layout_height="match_parent" />

    </LinearLayout>

</LinearLayout>
