<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/popup_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_text_tool_popup"
    android:elevation="16dp">

    <!-- ── Title Bar ── -->
    <LinearLayout
        android:id="@+id/tv_color_title"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <!-- Close -->
        <LinearLayout
            android:id="@+id/btn_color_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:background="@drawable/bg_lang_btn"
            android:layout_marginEnd="10dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textSize="14sp"
                android:textColor="#374151" />
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Text Color"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#111827" />

        <!-- Drag hint -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⠿ Drag &amp; Move"
            android:textSize="11sp"
            android:textColor="#9CA3AF"
            android:layout_marginEnd="12dp" />

        <!-- Done -->
        <TextView
            android:id="@+id/btn_color_done"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Done"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_continue_btn" />

    </LinearLayout>

    <!-- ── Tabs ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/tc_tab_solid"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="🎨 Solid"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_continue_btn"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tc_tab_gradient"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="🌈 Gradient"
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:background="@drawable/bg_lang_btn"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/btn_screen_pick"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="🖼 Image Picker"
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:background="@drawable/bg_lang_btn" />

    </LinearLayout>

    <!-- ── Solid Panel ── -->
    <LinearLayout
        android:id="@+id/tc_panel_solid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp"
        android:visibility="visible">

        <!-- Left: Color Grid -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/color_row"
            android:layout_width="0dp"
            android:layout_height="220dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp" />

        <!-- Right: Preview + HEX + Wheel -->
        <LinearLayout
            android:layout_width="130dp"
            android:layout_height="220dp"
            android:orientation="vertical">

            <!-- Color Preview -->
            <View
                android:id="@+id/view_hex_preview"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/bg_color_preview"
                android:layout_marginBottom="8dp" />

            <!-- HEX input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_lang_btn"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#"
                    android:textColor="#374151"
                    android:textSize="13sp"
                    android:paddingStart="8dp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_hex_color"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="FF0000"
                    android:textColor="#111827"
                    android:textSize="12sp"
                    android:background="@null"
                    android:paddingStart="4dp"
                    android:inputType="text"
                    android:maxLength="6"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/btn_hex_apply"
                    android:layout_width="36dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="OK"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_continue_btn" />

            </LinearLayout>

            <!-- Color Wheel -->
            <com.example.newcardmaker.ColorWheelView
                android:id="@+id/color_wheel"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── Gradient Panel ── -->
    <LinearLayout
        android:id="@+id/tc_panel_gradient"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp"
        android:visibility="gone">

        <!-- Gradient Preview -->
        <View
            android:id="@+id/tc_grad_preview"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/bg_color_preview"
            android:layout_marginBottom="8dp" />

        <!-- Color 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <View
                android:id="@+id/tc_grad_c1_box"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:background="#FF0000"
                android:layout_marginEnd="4dp" />

            <EditText
                android:id="@+id/tc_grad_c1_hex"
                android:layout_width="0dp"
                android:layout_height="26dp"
                android:layout_weight="1"
                android:text="FF0000"
                android:textColor="#111827"
                android:textSize="10sp"
                android:background="@drawable/bg_lang_btn"
                android:paddingHorizontal="4dp"
                android:inputType="text"
                android:maxLength="6"
                android:singleLine="true" />

            <View
                android:id="@+id/tc_grad_c2_box"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:background="#0000FF"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="4dp" />

            <EditText
                android:id="@+id/tc_grad_c2_hex"
                android:layout_width="0dp"
                android:layout_height="26dp"
                android:layout_weight="1"
                android:text="0000FF"
                android:textColor="#111827"
                android:textSize="10sp"
                android:background="@drawable/bg_lang_btn"
                android:paddingHorizontal="4dp"
                android:inputType="text"
                android:maxLength="6"
                android:singleLine="true" />

        </LinearLayout>

        <!-- Presets -->
        <LinearLayout
            android:id="@+id/tc_preset_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <View android:id="@+id/tc_preset_theme"   android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="#FF6B6B" />
            <View android:id="@+id/tc_preset_sunset"  android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="#FFA07A" />
            <View android:id="@+id/tc_preset_ocean"   android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="#4FC3F7" />
            <View android:id="@+id/tc_preset_gold"    android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="#FFD700" />
            <View android:id="@+id/tc_preset_forest"  android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="#66BB6A" />
            <View android:id="@+id/tc_preset_fire"    android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:background="#FF4500" />

        </LinearLayout>

        <!-- Direction -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView android:id="@+id/tc_dir_lr"   android:layout_width="40dp" android:layout_height="30dp" android:text="→" android:textColor="#FFFFFF" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_continue_btn" android:layout_marginEnd="4dp" />
            <TextView android:id="@+id/tc_dir_tb"   android:layout_width="40dp" android:layout_height="30dp" android:text="↓" android:textColor="#6B7280" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_lang_btn" android:layout_marginEnd="4dp" />
            <TextView android:id="@+id/tc_dir_diag" android:layout_width="40dp" android:layout_height="30dp" android:text="↘" android:textColor="#6B7280" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_lang_btn" android:layout_marginEnd="4dp" />

        </LinearLayout>

        <!-- Hidden buttons -->
        <TextView android:id="@+id/btn_color_cancel" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/btn_hex_apply2"   android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
