<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/grid_popup_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_grid_popup"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tv_grid_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingBottom="6dp"
        android:text="Grid Edit"
        android:textColor="#1565C0"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_grid_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingBottom="8dp"
        android:text="Rows: 3  Cols: 4  Size: 200"
        android:textColor="#444444"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_grid_cell_photo"
            style="@style/GridPopupButton"
            android:text="Cell Photo" />

    <!--    <TextView
            android:id="@+id/btn_grid_multi_photo"
            style="@style/GridPopupButton"
            android:text="Multi Photo" />-->

<!--        <TextView-->
<!--            android:id="@+id/btn_grid_size_minus"-->
<!--            style="@style/GridPopupButton"-->
<!--            android:text="Size -" />-->

<!--        <TextView-->
<!--            android:id="@+id/btn_grid_size_plus"-->
<!--            style="@style/GridPopupButton"-->
<!--            android:text="Size +" />-->


    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">


    </LinearLayout>

    <!--<LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_grid_row_minus"
            style="@style/GridPopupButton"
            android:text="Row -" />

        <TextView
            android:id="@+id/btn_grid_row_plus"
            style="@style/GridPopupButton"
            android:text="Row +" />

        <TextView
            android:id="@+id/btn_grid_col_minus"
            style="@style/GridPopupButton"
            android:text="Col -" />

        <TextView
            android:id="@+id/btn_grid_col_plus"
            style="@style/GridPopupButton"
            android:text="Col +" />

    </LinearLayout>
-->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_grid_full_edit"
            style="@style/GridPopupButton"
            android:text="Full Edit" />

        <TextView
            android:id="@+id/btn_grid_delete"
            style="@style/GridPopupButtonRed"
            android:text="Delete Grid" />

        <TextView
            android:id="@+id/btn_grid_transfer"
            style="@style/GridPopupButton"
            android:text="Trasfar" />

        <TextView
            android:id="@+id/btn_grid_cell_frame"
            style="@style/GridPopupButton"
            android:text="Style" />




    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_grid_close"
            style="@style/GridPopupButtonGray"
            android:text="Close" />

        <TextView
            android:id="@+id/btn_grid_edit_cell_frame"
            style="@style/GridPopupButtonGray"
            android:text="Edit mask " />
        <TextView
            android:id="@+id/btn_grid_list_view"
            style="@style/GridPopupButtonGray"
            android:text="list mask 1 " />



    </LinearLayout>


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="6dp"
        android:paddingBottom="2dp"
        android:text="Delete Cell Number"
        android:textColor="#444444"
        android:textSize="12sp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/et_grid_delete_number"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:background="#EEEEEE"
            android:hint="Cell no. e.g. 1"
            android:inputType="number"
            android:padding="8dp"
            android:text="5"
            android:textColor="#000000"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btn_grid_delete_cell_number"
            style="@style/GridPopupButtonRed"
            android:text="Delete Cell" />

        <TextView
            android:id="@+id/btn_grid_swap"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_margin="3dp"
            android:background="#E65100"
            android:gravity="center"
            android:padding="4dp"
            android:text="⇄ Cell Swap Mode"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

    </LinearLayout>


    <!-- Position Row — btnDeleteGrid ઉપર -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:visibility="gone"
        android:orientation="horizontal"
        android:padding="6dp">

        <TextView
            android:id="@+id/btn_grid_move_up"
            android:layout_width="0dp"
            android:layout_height="20dp"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:background="#37474F"
            android:gravity="center"
            android:padding="4dp"
            android:text="↑"
            android:textColor="@android:color/white"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/btn_grid_move_down"
            android:layout_width="0dp"
            android:layout_height="20dp"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:background="#37474F"
            android:gravity="center"
            android:padding="4dp"
            android:text="↓"
            android:textColor="@android:color/white"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/btn_grid_move_left"
            android:layout_width="0dp"
            android:layout_height="20dp"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:background="#37474F"
            android:gravity="center"
            android:padding="4dp"
            android:text="←"
            android:textColor="@android:color/white"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/btn_grid_move_right"
            android:layout_width="0dp"
            android:layout_height="20dp"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:background="#37474F"
            android:gravity="center"
            android:padding="4dp"
            android:text="→"
            android:textColor="@android:color/white"
            android:textSize="18sp" />

    </LinearLayout>


</LinearLayout>