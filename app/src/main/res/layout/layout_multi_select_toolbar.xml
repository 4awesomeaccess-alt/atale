<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/multi_select_toolbar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:elevation="4dp"
    android:orientation="vertical">

    <!-- ── Row 1: Title + Exit Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#1565C0"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✏️ Multi Select"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- ── Selected Count -->
        <TextView
            android:id="@+id/tv_selected_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="0 selected"
            android:textColor="#BBDEFB"
            android:textSize="11sp" />

        <!-- ── ✅ Multi Select OFF button -->
        <TextView
            android:id="@+id/btn_ms_cancel"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/invite_background_2_border_black_extra"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="✕ Exit"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- ── Row 2: Select Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E3F2FD"
        android:orientation="horizontal"
        android:padding="4dp">

        <Button
            android:id="@+id/btn_ms_select_all"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="3dp"
            android:layout_weight="1"
            android:backgroundTint="#1565C0"
            android:text="All"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btn_ms_unselect"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="3dp"
            android:layout_weight="1"
            android:backgroundTint="#607D8B"
            android:text="None"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btn_ms_copy"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="3dp"
            android:layout_weight="1"
            android:backgroundTint="#FF9800"
            android:text="Copy"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btn_ms_delete"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:backgroundTint="#F44336"
            android:text="🗑 Del"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- ── Row 3: Size Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FAFAFA"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="4dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp">

        <Button
            android:id="@+id/btn_ms_size_minus"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#455A64"
            android:text="−"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <android.widget.SeekBar
            android:id="@+id/seek_multi_size"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="50" />

        <Button
            android:id="@+id/btn_ms_size_plus"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#455A64"
            android:text="+"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_size_label"
            android:layout_width="56dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="+0.0sp"
            android:textColor="#555555"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- ── Row 4: Move Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FAFAFA"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp">

        <!-- Speed -->
        <Button
            android:id="@+id/btn_speed_slow"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="2dp"
            android:backgroundTint="#78909C"
            android:text="S"
            android:textColor="#FFFFFF"
            android:textSize="10sp" />

        <android.widget.SeekBar
            android:id="@+id/seek_move_speed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="2dp"
            android:layout_weight="1"
            android:max="9"
            android:progress="2" />

        <Button
            android:id="@+id/btn_speed_fast"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#78909C"
            android:text="F"
            android:textColor="#FFFFFF"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tv_move_speed"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:gravity="center"
            android:text="10px"
            android:textColor="#555555"
            android:textSize="10sp" />

        <!-- Arrow Buttons -->
        <Button
            android:id="@+id/btn_ms_up"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="2dp"
            android:backgroundTint="#1565C0"
            android:text="↑"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_ms_down"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="2dp"
            android:backgroundTint="#1565C0"
            android:text="↓"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_ms_left"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="2dp"
            android:backgroundTint="#1565C0"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_ms_right"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:backgroundTint="#1565C0"
            android:text="→"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Align Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/btn_ms_align_left"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="#E3F2FD"
            android:gravity="center"
            android:text="⬅\nLeft"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/btn_ms_align_center"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="#E3F2FD"
            android:gravity="center"
            android:text="↔\nCenter"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/btn_ms_align_right"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="#E3F2FD"
            android:gravity="center"
            android:text="➡\nRight"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/btn_ms_align_top"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="#E8F5E9"
            android:gravity="center"
            android:text="⬆\nTop"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/btn_ms_align_middle"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="#E8F5E9"
            android:gravity="center"
            android:text="↕\nMiddle"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/btn_ms_align_bottom"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="#E8F5E9"
            android:gravity="center"
            android:text="⬇\nBottom"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/btn_ms_distribute_h"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="#FFF8E1"
            android:gravity="center"
            android:text="⠿\nDist H"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/btn_ms_distribute_v"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="#FFF8E1"
            android:gravity="center"
            android:text="⠿\nDist V"
            android:textSize="10sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/drag_handle"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="#1565C0"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⠿⠿⠿  Multi Select  ⠿⠿⠿"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/btn_ms_group"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="2dp"
            android:background="#E8EAF6"
            android:gravity="center"
            android:text="📦\nGroup"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/btn_ms_show_groups"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="2dp"
            android:background="#E8EAF6"
            android:gravity="center"
            android:text="📋\nGroups"
            android:textSize="10sp" />

        <!-- Filter Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp">

            <TextView
                android:id="@+id/btn_ms_filter_all"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="All"
                android:textSize="11sp"
                android:background="#1565C0"
                android:textColor="#FFFFFF"
                android:layout_margin="2dp"/>

            <TextView
                android:id="@+id/btn_ms_filter_image"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="🖼 Image"
                android:textSize="11sp"
                android:background="#E3F2FD"
                android:textColor="#1565C0"
                android:layout_margin="2dp"/>

            <TextView
                android:id="@+id/btn_ms_filter_text"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="📝 Text"
                android:textSize="11sp"
                android:background="#E3F2FD"
                android:textColor="#1565C0"
                android:layout_margin="2dp"/>

        </LinearLayout>

    </LinearLayout>


</LinearLayout>